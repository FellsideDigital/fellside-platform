<div class="@(Center ? "text-center" : "")">
    @if (!string.IsNullOrEmpty(Label))
    {
        <p class="text-sm font-medium uppercase tracking-widest text-slate-400 dark:text-neutral-500">@Label</p>
    }
    <h2 class="mt-2 text-3xl font-semibold text-slate-900 dark:text-neutral-100 text-balance">@Heading</h2>
    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="mt-3 text-base text-slate-500 dark:text-neutral-400 @(Center ? "max-w-2xl mx-auto" : "max-w-2xl")">@Description</p>
    }
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string Heading { get; set; } = "";
    [Parameter] public string? Description { get; set; }
    [Parameter] public bool Center { get; set; }
}
