@namespace FellsideDigital.UI.Components.Tables

@* Standard table header cell. Use Right for right-aligned columns and Class for responsive visibility. *@
<th scope="col" class="@_classes">@ChildContent</th>

@code {
    [Parameter] public bool Right { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string _classes =>
        $"px-6 py-3.5 text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider {(Right ? "text-right" : "text-left")} {Class}".Trim();
}
