@namespace FellsideDigital.UI.Components.Feedback

@* Friendly fallback rendered by an <ErrorBoundary> when a page throws during render. *@
<div class="flex min-h-[40vh] flex-1 items-center justify-center p-12">
    <div class="max-w-md text-center">
        <div class="mx-auto mb-4 flex size-12 items-center justify-center rounded-2xl bg-red-50 dark:bg-red-400/10">
            <svg class="size-6 text-red-500 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
        </div>
        <p class="text-lg font-semibold text-gray-900 dark:text-white">Something went wrong</p>
        <p class="mt-1 text-sm text-gray-500 dark:text-neutral-400">@Message</p>
        <button type="button" onclick="location.reload()"
                class="mt-5 inline-flex items-center gap-1.5 rounded-xl bg-accent px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-accent-hover">
            Reload page
        </button>
    </div>
</div>

@code {
    [Parameter] public string Message { get; set; } =
        "This page hit an unexpected error. Reloading usually fixes it.";
}
