@using FellsideDigital.UI.Components.Icons
@using Microsoft.AspNetCore.Components.Routing

<NavLink href="@Href"
         Match="@Match"
         class="@ResolvedClass"
         ActiveClass="@ActiveClass"
         onclick="@OnClick"
         onclick:preventDefault="@Disabled">
    @if (Icon.HasValue)
    {
        <Icon Name="@Icon.Value" />
    }
    @ChildContent

</NavLink>

@code {
    [Parameter, EditorRequired]
    public string Href { get; set; } = default!;

    [Parameter]
    public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;

    [Parameter]
    public IconName? Icon { get; set; }

    [Parameter]
    public bool Disabled { get; set; } = false;

    [Parameter]
    public string Class { get; set; } =
        """
        navigation-button
        flex items-center gap-2.5 px-2.5 py-[9px]
        rounded-[10px]
        text-sm font-medium

        text-slate-500 dark:text-neutral-400

        hover:bg-slate-100
        dark:hover:bg-white/5

        hover:text-slate-900
        dark:hover:text-white

        transition-colors duration-150
        """;

    [Parameter]
    public string ActiveClass { get; set; } =
        """
        bg-accent/10
        !text-accent dark:!text-accent
        !font-medium

        hover:!bg-accent/10
        hover:!text-accent
        dark:hover:!text-accent
        """;

    private string ResolvedClass =>
        Disabled
            ? $"{Class} opacity-50 pointer-events-none cursor-not-allowed"
            : Class;

    private void OnClick(MouseEventArgs e)
    {
        if (Disabled)
        {
            return;
        }
    }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}