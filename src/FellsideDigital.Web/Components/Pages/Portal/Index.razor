@page "/Portal"
@attribute [Authorize]
@layout PortalLayout

@using System.Security.Claims
@using FellsideDigital.Domain.Enums
@using FellsideDigital.Domain.Extensions
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Web.Data
@using FellsideDigital.Web.Services
@using FellsideDigital.Web.Components.Layout
@using FellsideDigital.Web.Components.Shared

<PageTitle>Overview — Fellside Digital Portal</PageTitle>

@if (_loading)
{
    <div class="flex flex-col flex-1 gap-5 min-h-0 animate-pulse">
        <div class="shrink-0 space-y-2">
            <div class="h-4 w-20 rounded bg-gray-200 dark:bg-white/10"></div>
            <div class="h-7 w-56 rounded-lg bg-gray-200 dark:bg-white/10"></div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 shrink-0">
            @for (int i = 0; i < 4; i++) { <div class="h-24 rounded-2xl bg-gray-100 dark:bg-white/5"></div> }
        </div>
        <div class="flex-1 min-h-0 grid lg:grid-cols-5 gap-5">
            <div class="lg:col-span-3 rounded-2xl bg-gray-100 dark:bg-white/5"></div>
            <div class="lg:col-span-2 rounded-2xl bg-gray-100 dark:bg-white/5"></div>
        </div>
    </div>
}
else
{
    <div class="flex flex-col flex-1 min-h-0 gap-5">

        <!-- Overdue alert -->
        @if (_overdueInvoices.Any())
        {
            <div class="shrink-0 flex items-center gap-3 rounded-xl border border-red-200 dark:border-red-400/20
                        bg-red-50 dark:bg-red-400/10 px-4 py-3">
                <svg class="size-4 shrink-0 text-red-500 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                </svg>
                <p class="text-sm text-red-700 dark:text-red-400">
                    <span class="font-semibold">@_overdueInvoices.Count overdue invoice@(_overdueInvoices.Count == 1 ? "" : "s")</span>
                    · £@_overdueInvoices.Sum(i => i.Amount).ToString("N2") outstanding.
                    <NavLink href="/Portal/Invoices" class="underline underline-offset-2 ml-1 font-medium">View invoices →</NavLink>
                </p>
            </div>
        }

        <!-- Page header -->
        <div class="shrink-0">
            <p class="text-xs font-semibold text-accent-hover0 uppercase tracking-widest mb-1">Dashboard</p>
            <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
                @_greeting, @_firstName.
            </h1>
            <p class="mt-0.5 text-sm text-gray-500 dark:text-neutral-400">
                Here's what's happening with your @_companyName account.
            </p>
        </div>

        <!-- KPI stat cards -->
        <div class="shrink-0 grid grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm p-5">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Active</span>
                    <span class="flex size-7 items-center justify-center rounded-lg bg-blue-50 dark:bg-blue-400/10">
                        <svg class="size-3.5 text-blue-500 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                        </svg>
                    </span>
                </div>
                <p class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">@_projects.Count(p => p.Status == ProjectStatus.InProgress)</p>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Projects in progress</p>
            </div>

            <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm p-5">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Projects</span>
                    <span class="flex size-7 items-center justify-center rounded-lg bg-accent-hover">
                        <svg class="size-3.5 text-accent-hover0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
                        </svg>
                    </span>
                </div>
                <p class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">@_projects.Count</p>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">@_websites.Count site@(_websites.Count == 1 ? "" : "s"), @_automations.Count automation@(_automations.Count == 1 ? "" : "s")</p>
            </div>

            <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm p-5">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Outstanding</span>
                    <span class="flex size-7 items-center justify-center rounded-lg bg-amber-50 dark:bg-amber-400/10">
                        <svg class="size-3.5 text-amber-500 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                    </span>
                </div>
                <p class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">£@(_invoices.Where(i => i.Status is InvoiceStatus.Sent or InvoiceStatus.Overdue).Sum(i => i.Amount).ToString("N0"))</p>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Awaiting payment</p>
            </div>

            <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm p-5">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Paid</span>
                    <span class="flex size-7 items-center justify-center rounded-lg bg-emerald-50 dark:bg-emerald-400/10">
                        <svg class="size-3.5 text-emerald-500 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                    </span>
                </div>
                <p class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">£@(_invoices.Where(i => i.Status == InvoiceStatus.Paid).Sum(i => i.Amount).ToString("N0"))</p>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Total paid to date</p>
            </div>
        </div>

        <!-- Main content grid -->
        <div class="flex-1 min-h-0 grid grid-cols-1 lg:grid-cols-5 gap-5">

            <!-- Left: projects + activity -->
            <div class="lg:col-span-3 flex flex-col gap-4 min-h-0 overflow-y-auto">

                @if (_websites.Any())
                {
                    <div class="shrink-0 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm overflow-hidden">
                        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 dark:border-white/5">
                            <div class="flex items-center gap-2">
                                <div class="flex size-6 items-center justify-center rounded-md bg-accent-hover">
                                    <svg class="size-3.5 text-accent-hover0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />
                                    </svg>
                                </div>
                                <span class="text-sm font-semibold text-gray-900 dark:text-white">Websites</span>
                                <span class="text-xs text-gray-400 dark:text-neutral-500">(@_websites.Count)</span>
                            </div>
                            <NavLink href="/Portal/Websites" class="text-xs font-medium text-accent-hover0 hover:underline underline-offset-2">
                                View all →
                            </NavLink>
                        </div>
                        <div class="divide-y divide-gray-100 dark:divide-white/5">
                            @foreach (var p in _websites.Take(3)) { @ProjectRow(p) }
                        </div>
                    </div>
                }

                @if (_automations.Any())
                {
                    <div class="shrink-0 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm overflow-hidden">
                        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 dark:border-white/5">
                            <div class="flex items-center gap-2">
                                <div class="flex size-6 items-center justify-center rounded-md bg-accent-hover">
                                    <svg class="size-3.5 text-accent-hover0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                                    </svg>
                                </div>
                                <span class="text-sm font-semibold text-gray-900 dark:text-white">Automations</span>
                                <span class="text-xs text-gray-400 dark:text-neutral-500">(@_automations.Count)</span>
                            </div>
                            <NavLink href="/Portal/Automations" class="text-xs font-medium text-accent-hover0 hover:underline underline-offset-2">
                                View all →
                            </NavLink>
                        </div>
                        <div class="divide-y divide-gray-100 dark:divide-white/5">
                            @foreach (var p in _automations.Take(3)) { @ProjectRow(p) }
                        </div>
                    </div>
                }

                @if (!_projects.Any())
                {
                    <div class="flex-1 min-h-0 flex items-center justify-center rounded-2xl border border-dashed border-gray-200 dark:border-white/10 bg-white dark:bg-neutral-900">
                        <div class="text-center py-12 px-6">
                            <p class="text-sm font-semibold text-gray-900 dark:text-white">No projects yet</p>
                            <p class="text-xs text-gray-500 dark:text-neutral-400 mt-1">Your project manager will set these up shortly.</p>
                        </div>
                    </div>
                }

                @if (_recentActivity.Any())
                {
                    <div class="shrink-0 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm overflow-hidden">
                        <div class="px-5 py-4 border-b border-gray-100 dark:border-white/5">
                            <span class="text-sm font-semibold text-gray-900 dark:text-white">Recent activity</span>
                        </div>
                        <div class="divide-y divide-gray-100 dark:divide-white/5">
                            @foreach (var (update, project) in _recentActivity.Take(4))
                            {
                                <div class="flex items-start gap-3 px-5 py-3.5">
                                    <div class="flex size-6 shrink-0 items-center justify-center rounded-full mt-0.5
                                                @(update.NewStatus.HasValue ? "bg-accent-hover" : "bg-gray-100 dark:bg-white/5")">
                                        <div class="@(update.NewStatus.HasValue ? "size-2 rounded-full bg-accent" : "size-1.5 rounded-full bg-gray-300 dark:bg-white/20")"></div>
                                    </div>
                                    <div class="min-w-0 flex-1">
                                        <div class="flex items-center gap-1.5 flex-wrap">
                                            <span class="text-xs font-semibold text-gray-900 dark:text-white">@project.Name</span>
                                            @if (update.NewStatus.HasValue)
                                            {
                                                <span class="text-xs text-gray-400 dark:text-neutral-500">→ @update.NewStatus.Value.DisplayName()</span>
                                            }
                                            <time class="text-xs text-gray-400 dark:text-neutral-500 ml-auto">@update.CreatedAt.ToLocalTime().ToString("d MMM")</time>
                                        </div>
                                        <p class="text-xs text-gray-500 dark:text-neutral-400 truncate mt-0.5">@update.Message</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Right: invoices + help -->
            <div class="lg:col-span-2 flex flex-col gap-4 min-h-0 overflow-y-auto">

                <div class="shrink-0 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm overflow-hidden">
                    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 dark:border-white/5">
                        <span class="text-sm font-semibold text-gray-900 dark:text-white">Invoices</span>
                        <NavLink href="/Portal/Invoices" class="text-xs font-medium text-accent-hover0 hover:underline underline-offset-2">View all →</NavLink>
                    </div>
                    @if (!_invoices.Any())
                    {
                        <div class="px-5 py-8 text-center">
                            <p class="text-sm text-gray-400 dark:text-neutral-500">No invoices yet.</p>
                        </div>
                    }
                    else
                    {
                        <ul role="list" class="divide-y divide-gray-100 dark:divide-white/5">
                            @foreach (var inv in _invoices.Take(4))
                            {
                                <li class="flex items-center gap-3 px-5 py-3.5 hover:bg-gray-50 dark:hover:bg-white/[0.02] transition-colors">
                                    <div class="min-w-0 flex-1">
                                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@inv.Title</p>
                                        <p class="text-xs text-gray-400 dark:text-neutral-500 mt-0.5">
                                            @inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")
                                            @if (inv.DueAt.HasValue && inv.Status != InvoiceStatus.Paid)
                                            {
                                                <span class="@(inv.DueAt < DateTime.UtcNow ? "text-red-500 dark:text-red-400 font-medium" : "")">
                                                    · Due @inv.DueAt.Value.ToLocalTime().ToString("d MMM")
                                                </span>
                                            }
                                        </p>
                                    </div>
                                    <div class="shrink-0 text-right">
                                        <p class="text-sm font-semibold text-gray-900 dark:text-white">£@inv.Amount.ToString("N0")</p>
                                        <StatusBadge CssClasses="@BadgeHelpers.InvoiceStatusBadge(inv.Status)" Label="@inv.Status.ToString()" />
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>

                <div class="shrink-0 rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 shadow-sm p-5">
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Need help?</h3>
                    <div class="space-y-2">
                        <a href="tel:+447484323505"
                           class="flex items-center gap-3 rounded-xl px-4 py-3
                                  bg-gray-50 dark:bg-white/5 hover:bg-accent-hover
                                  text-gray-700 dark:text-neutral-300 hover:text-accent
                                  transition-colors group">
                            <svg class="size-4 shrink-0 text-gray-400 dark:text-neutral-500 group-hover:text-accent-hover0 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                            </svg>
                            <span class="text-sm font-medium">+44 (0) 7484 323 505</span>
                        </a>
                        <a href="https://wa.me/447484323505" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-3 rounded-xl px-4 py-3
                                  bg-gray-50 dark:bg-white/5 hover:bg-accent-hover
                                  text-gray-700 dark:text-neutral-300 hover:text-accent
                                  transition-colors group">
                            <svg class="size-4 shrink-0 text-gray-400 dark:text-neutral-500 group-hover:text-accent-hover0 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                            </svg>
                            <span class="text-sm font-medium">Chat on WhatsApp</span>
                        </a>
                        <a href="https://outlook.office.com/book/FellsideDigitalBookings1@fellsidedigital.co.uk/s/yUi6sJXH6ky72yJsPhKhQg2?ismsaljsauthenabled"
                           target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-3 rounded-xl px-4 py-3
                                  bg-gray-50 dark:bg-white/5 hover:bg-accent-hover
                                  text-gray-700 dark:text-neutral-300 hover:text-accent
                                  transition-colors group">
                            <svg class="size-4 shrink-0 text-gray-400 dark:text-neutral-500 group-hover:text-accent-hover0 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                            </svg>
                            <span class="text-sm font-medium">Book a support call</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private RenderFragment ProjectRow(ClientProject p) =>
        @<NavLink href="@($"/Portal/Projects/{p.Id}")"
                  class="group flex items-center justify-between px-5 py-4
                         hover:bg-gray-50 dark:hover:bg-white/[0.02] transition-colors">
            <div class="flex items-center gap-3 min-w-0">
                <div class="flex size-8 shrink-0 items-center justify-center rounded-lg
                            bg-gray-100 dark:bg-white/5
                            group-hover:bg-accent-hover transition-colors">
                    <div class="size-2 rounded-full @StatusDot(p.Status)"></div>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-gray-900 dark:text-white truncate
                               group-hover:text-accent transition-colors">
                        @p.Name
                    </p>
                    <p class="text-xs text-gray-400 dark:text-neutral-500 truncate">
                        @p.Invoices.Count invoice@(p.Invoices.Count == 1 ? "" : "s")
                        @if (p.StatusUpdates.Any())
                        {
                            <text>· Updated @p.StatusUpdates.Max(u => u.CreatedAt).ToLocalTime().ToString("d MMM")</text>
                        }
                    </p>
                </div>
            </div>
            <div class="flex items-center gap-3 shrink-0 ml-4">
                <StatusBadge CssClasses="@BadgeHelpers.ProjectStatusBadge(p.Status)" Label="@p.Status.DisplayName()" />
                <svg class="size-4 text-gray-300 dark:text-neutral-600 group-hover:text-accent transition-colors"
                     fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
            </div>
        </NavLink>;

    private static string StatusDot(ProjectStatus s) => s switch
    {
        ProjectStatus.InProgress => "bg-blue-400",
        ProjectStatus.Completed  => "bg-emerald-400",
        ProjectStatus.Blocked    => "bg-red-400",
        ProjectStatus.OnHold     => "bg-amber-400",
        _                        => "bg-gray-300 dark:bg-white/20",
    };
}
