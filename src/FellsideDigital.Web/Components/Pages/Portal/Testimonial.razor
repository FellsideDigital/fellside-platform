@page "/Portal/Testimonial"
@attribute [Authorize]
@layout PortalLayout

@using FellsideDigital.Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using FellsideDigital.Web.Components.Layout

<PageTitle>Leave a testimonial — Fellside Digital Portal</PageTitle>

<PageHeader Eyebrow="Your feedback"
            Title="Thank you for taking the time to write us a testimonial"
            Description="Your words help other businesses know what it's like to work with us. It only takes a minute." />

<div class="max-w-2xl">
    @if (!_loaded)
    {
        <div class="animate-pulse space-y-3">
            <div class="h-32 rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900"></div>
        </div>
    }
    else
    {
        <CardSection Title="Your testimonial"
                     Subtitle="Pick a rating and tell us how it went."
                     HeaderPadding="py-5">
            <div class="px-6 py-6">

                @if (_currentStatus == TestimonialStatus.Approved)
                {
                    <AlertBanner Message="Your testimonial is live on our site — thank you! You can update it below; edits go back for review."
                                 Variant="success" Class="mb-5" />
                }
                else if (_currentStatus == TestimonialStatus.Pending)
                {
                    <AlertBanner Message="Thanks! Your testimonial is awaiting review. You can keep editing it below until it's approved."
                                 Variant="accent" Class="mb-5" />
                }

                <AlertBanner Message="@_error" Variant="error" Class="mb-5" />

                <EditForm Model="Input" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-900 dark:text-white mb-2">
                            How would you rate your experience? <span class="text-red-500">*</span>
                        </label>
                        <div class="flex items-center gap-1">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var value = i;
                                <button type="button"
                                        @onclick="() => SetRating(value)"
                                        aria-label="@($"{value} star{(value == 1 ? "" : "s")}")"
                                        class="p-1 rounded-md transition-colors hover:scale-110">
                                    <svg class="size-8 @(value <= _rating ? "text-accent" : "text-slate-200 dark:text-neutral-700")"
                                         viewBox="0 0 20 20" fill="currentColor">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">
                            Your testimonial <span class="text-red-500">*</span>
                        </label>
                        <InputTextArea @bind-Value="Input.Quote" rows="5"
                                       placeholder="Tell us what it was like working with Fellside Digital…"
                                       class="@InputClass" />
                        <ValidationMessage For="() => Input.Quote" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                    </div>

                    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                        <div>
                            <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">
                                Your name <span class="text-red-500">*</span>
                            </label>
                            <InputText @bind-Value="Input.AuthorName" placeholder="Jane Cooper" class="@InputClass" />
                            <ValidationMessage For="() => Input.AuthorName" class="mt-1 text-xs text-red-600 dark:text-red-400" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1.5">
                                Company name
                            </label>
                            <InputText @bind-Value="Input.AuthorRole" placeholder="Director, Acme Ltd" class="@InputClass" />
                            <p class="mt-1 text-xs text-gray-400 dark:text-neutral-500">Shown beneath your name on the site.</p>
                        </div>
                    </div>

                    <div class="mt-6">
                        <SpinnerButton IsLoading="@_saving" LoadingText="Submitting…">
                            @(_currentStatus is null ? "Submit testimonial" : "Update testimonial")
                        </SpinnerButton>
                    </div>
                </EditForm>
            </div>
        </CardSection>
    }
</div>
