@using FellsideDigital.Web.Data
@using FellsideDigital.Domain.Enums

<div class="space-y-5">

    @* Page header row *@
    <div class="flex items-end justify-between gap-4 flex-wrap">
        <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-1">Overview</p>
            <h1 class="text-[28px] font-semibold tracking-tight text-gray-900 dark:text-white leading-tight">
                Welcome back, @FirstName.
            </h1>
            <p class="mt-1 text-sm text-gray-400 dark:text-neutral-500">
                Here's where your build stands today, @DateTime.Now.ToString("d MMMM yyyy").
            </p>
        </div>
@*         <NavLink href="@($"/Portal/Projects/{Project.Id}")"
                 class="inline-flex items-center gap-2 rounded-[10px] bg-accent px-[18px] py-[10px]
                        text-sm font-semibold text-white shadow-sm hover:opacity-90 transition-opacity shrink-0">
            Open project
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
        </NavLink> *@
    </div>

    @* Hero card *@
    <div class="relative overflow-hidden rounded-[20px] bg-white dark:bg-neutral-900
                border border-gray-200/80 dark:border-white/10 shadow-sm p-7">
        <div class="portal-hero-aura"></div>
        <div class="relative grid grid-cols-1 lg:grid-cols-[1fr_220px] gap-8 items-center">
            <div>
                <span class="text-[11px] font-semibold uppercase tracking-widest text-accent">
                    @TypeLabel
                </span>
                <h2 class="mt-2 mb-1.5 text-[26px] font-semibold tracking-tight text-gray-900 dark:text-white">
                    @Project.Name
                </h2>
                <p class="text-sm text-gray-500 dark:text-neutral-400 leading-relaxed max-w-[520px] mb-[18px]">
                    @Project.Description
                </p>
                <div class="flex gap-6 flex-wrap text-xs text-gray-500 dark:text-neutral-400 mb-5">
                    <span>
                        <strong class="text-gray-900 dark:text-white font-semibold">Started</strong>
                        · @Project.CreatedAt.ToLocalTime().ToString("d MMM yyyy")
                    </span>
                    <span>
                        <strong class="text-gray-900 dark:text-white font-semibold">Target launch</strong>
                        · @TargetLaunchLabel
                    </span>
                    <span>
                        <strong class="text-gray-900 dark:text-white font-semibold">Current phase</strong>
                        · @CurrentPhaseShort
                    </span>
                </div>
                <div class="flex gap-2.5 flex-wrap">
                    <NavLink href="@($"/Portal/Projects/{Project.Id}")"
                             class="rounded-[10px] bg-accent px-[16px] py-[9px] text-sm font-semibold
                                    text-white shadow-sm hover:opacity-90 transition-opacity">
                        Open project
                    </NavLink>
                    <a href="/Portal/Settings"
                       class="rounded-[10px] border border-gray-200 dark:border-white/10
                              bg-white dark:bg-neutral-900 px-[14px] py-[9px]
                              text-sm font-medium text-gray-700 dark:text-neutral-300
                              hover:border-gray-300 dark:hover:border-white/20 transition-colors">
                        Get in touch
                    </a>
                </div>
            </div>
            <ProgressRing Value="@Project.ProgressPercent" />
        </div>
    </div>

    @* 3 KPI cards *@
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3.5">
        <KpiCard Eyebrow="Current phase"
                 Value="@CurrentPhaseShort"
                 Sub="@CurrentPhaseSub"
                 IconPath="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
                 Tone="blue" />
        <KpiCard Eyebrow="Days to launch"
                 Value="@DaysToLaunchStr"
                 Sub="@TargetLaunchSub"
                 IconPath="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                 Tone="amber" />
        <KpiCard Eyebrow="Outstanding"
                 Value="@OutstandingStr"
                 Sub="@OutstandingSub"
                 IconPath="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"
                 Tone="rose" />
    </div>

    @* Two-column: milestones + activity *@
    <div class="grid grid-cols-1 lg:grid-cols-[1.6fr_1fr] gap-5 items-stretch">

        @* Milestones panel *@
        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/10 overflow-hidden flex flex-col">
            <div class="flex items-center justify-between px-5 py-[18px] border-b border-gray-100 dark:border-white/5 shrink-0">
                <h3 class="text-base font-semibold text-gray-900 dark:text-white">Project plan</h3>
                <NavLink href="@($"/Portal/Projects/{Project.Id}")"
                         class="text-accent text-sm font-semibold hover:opacity-80 transition-opacity">
                    View project →
                </NavLink>
            </div>
            @if (!_projectPlan.Any())
            {
                <div class="px-5 py-10 text-center">
                    <div class="inline-flex size-14 items-center justify-center rounded-2xl bg-gray-50 dark:bg-white/5 mb-3">
                        <svg class="size-5 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24"
                             stroke-width="1.75" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white">No milestones yet</p>
                    <p class="text-xs text-gray-400 dark:text-neutral-500 mt-1">We'll add these once discovery wraps up.</p>
                </div>
            }
            else
            {
                <div class="py-1 overflow-y-auto">
                    @foreach (var ms in _projectPlan)
                    {
                        var isActive = ms.Status != PhaseStatus.Completed;
                        var dotClass = isActive
                            ? "bg-accent border-accent ring-4 ring-accent/20"
                            : "bg-emerald-400 border-emerald-400";
                        var titleClass = isActive
                            ? "text-gray-900 dark:text-white"
                            : "text-gray-400 dark:text-neutral-500";

                        <div class="portal-ms-item border-b border-gray-50 dark:border-white/[0.04] last:border-0 py-3.5 pl-14 pr-5">
                            <span class="absolute left-[22px] top-[18px] size-3.5 rounded-full border-2 @dotClass"></span>
                            <p class="text-sm font-semibold @titleClass">@ms.Title</p>
                            <p class="text-xs text-gray-400 dark:text-neutral-500 mt-0.5">
                                @ms.ShortLabel · @ms.CreatedAt.ToLocalTime().ToString("d MMM yyyy")
                                <span> · @ms.Status.DisplayName()</span>
                            </p>
                        </div>
                    }
                </div>
            }
        </div>

        @* Activity panel *@
        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/10 overflow-hidden flex flex-col">
            <div class="flex items-center justify-between px-5 py-[18px] border-b border-gray-100 dark:border-white/5 shrink-0">
                <h3 class="text-base font-semibold text-gray-900 dark:text-white">Recent activity</h3>
                <NavLink href="@($"/Portal/Projects/{Project.Id}")"
                         class="text-accent text-sm font-semibold hover:opacity-80 transition-opacity">
                    All updates →
                </NavLink>
            </div>
            <div class="overflow-y-auto">
                <ProjectTimeline Events="_activity"
                                 Audience="FellsideDigital.Web.Services.TimelineAudience.Client"
                                 Max="6"
                                 OldestFirst="true"
                                 TimeFormat="d MMM yyyy"
                                 EmptyText="No activity yet." />
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ClientProject Project  { get; set; } = default!;
    [Parameter]                 public string       FirstName { get; set; } = "there";

    private IReadOnlyList<ProjectPlanPhase> _projectPlan = [];
    private IReadOnlyList<ProjectTimelineEvent> _activity = [];

    protected override void OnParametersSet()
    {
        _projectPlan = Project.PlanPhases
            .OrderBy(u => u.CreatedAt)
            .ToList();

        _activity = Project.TimelineEvents
            .OrderByDescending(e => e.OccurredAt)
            .ToList();
    }

    private string TypeLabel => Project.Type switch
    {
        ProjectType.Website    => "Marketing website",
        ProjectType.Automation => "Automation project",
        _                      => Project.Type.ToString(),
    };

    private string TargetLaunchLabel => Project.TargetLaunchDate.HasValue
        ? Project.TargetLaunchDate.Value.ToString("d MMM yyyy")
        : "To be confirmed";

    // Phase selection + label come from ClientProject so this matches the admin view.
    private string CurrentPhaseShort => Project.CurrentPhaseShortLabel;

    // Overview keeps a "Since {date}" sub-line rather than the status used elsewhere.
    private string CurrentPhaseSub => Project.CurrentPhase is { } p
        ? "Since " + p.CreatedAt.ToLocalTime().ToString("d MMM")
        : "Project just started";

    private string DaysToLaunchStr
    {
        get
        {
            if (!Project.TargetLaunchDate.HasValue) return "—";
            var days = (int)(Project.TargetLaunchDate.Value.Date - DateTime.Today).TotalDays;
            return days >= 0 ? days.ToString() : "0";
        }
    }

    private string TargetLaunchSub => Project.TargetLaunchDate.HasValue
        ? "Target " + Project.TargetLaunchDate.Value.ToString("d MMM yyyy")
        : "No target date set";

    private decimal OutstandingTotal => Project.Invoices
        .Where(i => i.Status is InvoiceStatus.Sent or InvoiceStatus.Overdue)
        .Sum(i => i.Amount);

    private string OutstandingStr => $"£{OutstandingTotal:N0}";

    private string OutstandingSub
    {
        get
        {
            var count = Project.Invoices.Count(i => i.Status is InvoiceStatus.Sent or InvoiceStatus.Overdue);
            return count == 0 ? "All invoices paid" : $"{count} invoice{(count == 1 ? "" : "s")} outstanding";
        }
    }
}
