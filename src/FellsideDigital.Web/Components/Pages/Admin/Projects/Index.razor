@page "/Admin/Projects"
@attribute [Authorize(Roles = "SiteAdmin")]
@layout AdminLayout

@using FellsideDigital.Domain.Enums
@using FellsideDigital.Domain.Extensions
@using FellsideDigital.UI.Layout
@using FellsideDigital.Web.Components.Layout
@using FellsideDigital.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization

<PageTitle>Projects — Fellside Digital Admin</PageTitle>

<PageHeader Eyebrow="Admin" Title="Client Projects" Description="Create and manage projects for your clients.">
    <Actions>
        <PrimaryButton Color="ButtonColor.Muted" Style="ButtonStyle.Outline" Href="/Admin/Invitations">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            Invitations
        </PrimaryButton>
        <PrimaryButton Href="/Admin/Projects/Create">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            New project
        </PrimaryButton>
    </Actions>
</PageHeader>

@if (_projects is null)
{
    <div class="animate-pulse space-y-3">
        <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-12"></div>
        @for (int i = 0; i < 5; i++)
        {
            <div class="rounded-xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-16"></div>
        }
    </div>
}
else if (_projects.Count == 0)
{
    <EmptyState Padding="p-14"
                IconContainerClass="size-12 rounded-2xl mb-4"
                Title="No projects yet"
                Subtitle="Create your first project to get started.">
        <Icon>
            <svg class="size-6 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
            </svg>
        </Icon>
        <Actions>
            <a href="/Admin/Projects/Create"
               class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:underline">
                Create a project →
            </a>
        </Actions>
    </EmptyState>
}
else
{
    <!-- Summary stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-4 shadow-sm">
            <p class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Total</p>
            <p class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">@_projects.Count</p>
        </div>
        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-4 shadow-sm">
            <p class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Active</p>
            <p class="text-2xl font-bold tracking-tight text-blue-600 dark:text-blue-400">@_projects.Count(p => p.Status == ProjectStatus.InProgress)</p>
        </div>
        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-4 shadow-sm">
            <p class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Complete</p>
            <p class="text-2xl font-bold tracking-tight text-emerald-600 dark:text-emerald-400">@_projects.Count(p => p.Status == ProjectStatus.Completed)</p>
        </div>
        <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-gray-200/80 dark:border-white/5 p-4 shadow-sm">
            <p class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">On Hold</p>
            <p class="text-2xl font-bold tracking-tight text-amber-600 dark:text-amber-400">@_projects.Count(p => p.Status == ProjectStatus.OnHold || p.Status == ProjectStatus.Blocked)</p>
        </div>
    </div>

    <!-- Table -->
    <CardSection>
        <table class="min-w-full divide-y divide-gray-100 dark:divide-white/5">
            <thead>
                <tr class="bg-gray-50/80 dark:bg-white/[0.02]">
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Project</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider hidden sm:table-cell">Client</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider hidden md:table-cell">Type</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Status</th>
                    <th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider hidden lg:table-cell">Invoices</th>
                    <th scope="col" class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                @foreach (var project in _projects)
                {
                    <tr class="hover:bg-gray-50/50 dark:hover:bg-white/[0.02] transition-colors group">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="flex size-8 shrink-0 items-center justify-center rounded-lg bg-gray-100 dark:bg-white/5">
                                    <div class="size-2 rounded-full @BadgeHelpers.ProjectStatusDotColor(project.Status)"></div>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-gray-900 dark:text-white">@project.Name</p>
                                    <p class="text-xs text-gray-500 dark:text-neutral-400 truncate max-w-[200px]">@project.Description</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 hidden sm:table-cell">
                            <p class="text-sm text-gray-700 dark:text-neutral-300">@project.Client?.CompanyName</p>
                            <p class="text-xs text-gray-500 dark:text-neutral-400">@project.Client?.Email</p>
                        </td>
                        <td class="px-6 py-4 hidden md:table-cell">
                            <StatusBadge CssClasses="bg-gray-100 text-gray-600 dark:bg-white/5 dark:text-neutral-400"
                                         Label="@project.Type.DisplayName()" />
                        </td>
                        <td class="px-6 py-4">
                            <StatusBadge CssClasses="@BadgeHelpers.ProjectStatusBadge(project.Status)"
                                         Label="@project.Status.DisplayName()" />
                        </td>
                        <td class="px-6 py-4 hidden lg:table-cell">
                            <span class="text-sm text-gray-500 dark:text-neutral-400">
                                @project.Invoices.Count invoice@(project.Invoices.Count == 1 ? "" : "s")
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-1.5">
                                <a href="@($"/Admin/Projects/{project.Id}")"
                                   class="text-xs font-semibold text-accent hover:underline transition-colors mr-2">
                                    Manage
                                </a>
                                <a href="@($"/Admin/Projects/{project.Id}/Edit")"
                                   title="Edit project"
                                   class="inline-flex size-8 items-center justify-center rounded-lg text-gray-500 dark:text-neutral-400
                                          hover:bg-gray-100 dark:hover:bg-white/5 hover:text-gray-900 dark:hover:text-white transition-colors">
                                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                                    </svg>
                                </a>
                                <a href="@($"/Admin/Projects/{project.Id}/PortalPreview")"
                                   title="Preview as client"
                                   class="inline-flex size-8 items-center justify-center rounded-lg text-gray-500 dark:text-neutral-400
                                          hover:bg-gray-100 dark:hover:bg-white/5 hover:text-gray-900 dark:hover:text-white transition-colors">
                                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                    </svg>
                                </a>
                                <button type="button"
                                        title="Delete project"
                                        @onclick="@(() => _pendingDelete = project)"
                                        class="inline-flex size-8 items-center justify-center rounded-lg text-gray-500 dark:text-neutral-400
                                               hover:bg-red-50 dark:hover:bg-red-500/10 hover:text-red-600 dark:hover:text-red-400 transition-colors">
                                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </CardSection>
}
