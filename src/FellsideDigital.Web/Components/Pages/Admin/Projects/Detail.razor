@page "/Admin/Projects/{Id:guid}"
@attribute [Authorize(Roles = "SiteAdmin")]
@layout AdminLayout

@using FellsideDigital.Domain.Enums
@using FellsideDigital.Domain.Extensions
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Web.Data
@using FellsideDigital.Web.Services
@using FellsideDigital.Web.Components.Layout
@using FellsideDigital.Web.Components.Shared

<PageTitle>@(_project?.Name ?? "Project") — Fellside Digital Admin</PageTitle>

@if (_project is null)
{
    <div class="animate-pulse space-y-5">
        <div class="h-8 w-64 rounded-lg bg-gray-200 dark:bg-white/10"></div>
        <div class="grid grid-cols-1 lg:grid-cols-[1.7fr_1fr] gap-5">
            <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-56"></div>
            <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-56"></div>
        </div>
        <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-64"></div>
    </div>
}
else
{
    <div class="space-y-5">

        <!-- ── Header row ── -->
        <div>
            <a href="/Admin/Projects"
               class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-3">
                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                </svg>
                Projects
            </a>
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <div class="flex items-center gap-3">
                    <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">@_project.Name</h1>
                    <StatusBadge CssClasses="@BadgeHelpers.ProjectStatusBadge(_project.Status)"
                                 Dot="@BadgeHelpers.ProjectStatusDotColor(_project.Status)"
                                 Label="@_project.Status.DisplayName()" />
                </div>
                <div class="flex flex-wrap items-center gap-2 sm:justify-end">
                    <PrimaryButton Color="ButtonColor.Muted" Style="ButtonStyle.Outline" Href="@($"/Admin/Projects/{Id}/PortalPreview")">
                        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                        Preview as client
                    </PrimaryButton>
                    <PrimaryButton Color="ButtonColor.Muted" Style="ButtonStyle.Outline" Href="@($"/Admin/Projects/{Id}/Edit")">
                        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                        </svg>
                        Edit project
                    </PrimaryButton>
                    <button type="button" @onclick="() => _showDelete = true"
                            class="inline-flex items-center gap-1.5 rounded-xl px-3.5 py-2.5 text-sm font-semibold
                                   text-red-500 dark:text-red-400 ring-1 ring-inset ring-red-200 dark:ring-red-500/30
                                   hover:bg-red-50 dark:hover:bg-red-500/10 hover:text-red-600 dark:hover:text-red-300
                                   transition-colors">
                        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                        Delete
                    </button>
                </div>
            </div>
        </div>

        <!-- ── Top: project hero + client card ── -->
        <div class="grid grid-cols-1 lg:grid-cols-[1.7fr_1fr] gap-5 items-stretch">

            <!-- Project hero -->
            <div class="relative overflow-hidden rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm p-6">
                <div class="portal-hero-aura"></div>
                <div class="relative grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-6 items-center">
                    <div class="min-w-0">
                        <span class="text-xs font-semibold uppercase tracking-widest text-accent">@TypeLabel</span>
                        <h2 class="mt-2 mb-1.5 text-xl font-semibold tracking-tight text-gray-900 dark:text-white">@_project.Name</h2>
                        <p class="text-sm text-gray-500 dark:text-neutral-400 leading-relaxed max-w-[520px] mb-4">@_project.Description</p>
                        <div class="flex gap-x-6 gap-y-1.5 flex-wrap text-xs text-gray-500 dark:text-neutral-400 mb-4">
                            <span><strong class="text-gray-900 dark:text-white font-semibold">Started</strong> · @_project.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</span>
                            <span><strong class="text-gray-900 dark:text-white font-semibold">Target launch</strong> · @(_project.TargetLaunchDate?.ToLocalTime().ToString("d MMM yyyy") ?? "TBC")</span>
                            <span><strong class="text-gray-900 dark:text-white font-semibold">Updated</strong> · @_project.UpdatedAt.ToLocalTime().ToString("d MMM yyyy")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(_project.PreviewUrl) || !string.IsNullOrEmpty(_project.ProjectUrl))
                        {
                            <div class="flex gap-2.5 flex-wrap">
                                @if (!string.IsNullOrEmpty(_project.PreviewUrl))
                                {
                                    <a href="@_project.PreviewUrl" target="_blank" rel="noopener"
                                       class="inline-flex items-center gap-1.5 rounded-xl bg-accent px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:opacity-90 transition-opacity">
                                        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                        </svg>
                                        View live preview
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(_project.ProjectUrl))
                                {
                                    <a href="@_project.ProjectUrl" target="_blank" rel="noopener"
                                       class="inline-flex items-center gap-1.5 rounded-xl border border-gray-200 dark:border-white/10 bg-white dark:bg-neutral-900 px-3.5 py-2 text-sm font-medium text-gray-700 dark:text-neutral-300 hover:border-gray-300 dark:hover:border-white/20 transition-colors">
                                        Project URL
                                    </a>
                                }
                            </div>
                        }
                    </div>
                    <ProgressRing Value="@ProgressPct" Size="150" Stroke="12" />
                </div>
            </div>

            <!-- Client card -->
            <CardSection Title="Client">
                <div class="px-6 py-5">
                    <div class="flex items-center gap-3.5 mb-5">
                        <div class="flex size-12 shrink-0 items-center justify-center rounded-full bg-accent/10 text-accent text-base font-bold">
                            @ClientInitials
                        </div>
                        <div class="min-w-0">
                            <p class="text-sm font-semibold text-gray-900 dark:text-white truncate">@ClientName</p>
                            @if (!string.IsNullOrWhiteSpace(_project.Client?.CompanyName))
                            {
                                <p class="text-xs text-gray-500 dark:text-neutral-400 truncate">@_project.Client!.CompanyName</p>
                            }
                        </div>
                    </div>

                    <dl class="space-y-3 text-sm">
                        <div class="flex items-start gap-2.5">
                            <svg class="size-4 mt-0.5 shrink-0 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                            </svg>
                            @if (!string.IsNullOrWhiteSpace(_project.Client?.Email))
                            {
                                <a href="mailto:@_project.Client!.Email" class="text-accent hover:underline break-all">@_project.Client!.Email</a>
                            }
                            else
                            {
                                <span class="text-gray-400 dark:text-neutral-500">No email</span>
                            }
                        </div>
                        <div class="flex items-start gap-2.5">
                            <svg class="size-4 mt-0.5 shrink-0 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                            </svg>
                            @if (!string.IsNullOrWhiteSpace(_project.Client?.PhoneNumber))
                            {
                                <span class="text-gray-700 dark:text-neutral-300">@_project.Client!.PhoneNumber</span>
                            }
                            else
                            {
                                <span class="text-gray-400 dark:text-neutral-500">No phone</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_project.Client?.ServiceType))
                        {
                            <div class="flex items-start gap-2.5">
                                <svg class="size-4 mt-0.5 shrink-0 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                                </svg>
                                <span class="text-gray-700 dark:text-neutral-300">@_project.Client!.ServiceType</span>
                            </div>
                        }
                    </dl>

                    @if (!string.IsNullOrWhiteSpace(_project.Client?.Notes))
                    {
                        <div class="mt-4 rounded-xl bg-gray-50 dark:bg-white/5 px-3.5 py-3">
                            <p class="text-[11px] font-semibold uppercase tracking-wider text-gray-400 dark:text-neutral-500 mb-1">Notes</p>
                            <p class="text-xs text-gray-600 dark:text-neutral-300 leading-relaxed">@_project.Client!.Notes</p>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(_project.Client?.Email))
                    {
                        <a href="mailto:@_project.Client!.Email"
                           class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:opacity-80 transition-opacity">
                            Email client
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                            </svg>
                        </a>
                    }
                </div>
            </CardSection>
        </div>

        <!-- ── KPI cards ── -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3.5">
            <KpiCard Eyebrow="Current phase"
                     Value="@CurrentPhaseShort"
                     Sub="@CurrentPhaseSub"
                     IconPath="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
                     Tone="blue" />
            <KpiCard Eyebrow="Days to launch"
                     Value="@DaysToLaunchStr"
                     Sub="@TargetLaunchSub"
                     IconPath="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                     Tone="amber" />
            <KpiCard Eyebrow="Outstanding"
                     Value="@OutstandingStr"
                     Sub="@OutstandingSub"
                     IconPath="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"
                     Tone="rose" />
        </div>

        <!-- ── Main widgets: uniform dashboard cards (equal size, internal scroll) ── -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

                <!-- Project plan -->
                <CardSection Class="flex flex-col h-[28rem]">
                    <Header>
                        <div class="flex items-center justify-between">
                            <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Project plan</h2>
                            @if (_project.PlanPhases.Any())
                            {
                                <span class="text-xs text-gray-400 dark:text-neutral-500">@CompletedPhaseCount of @_project.PlanPhases.Count complete · @ProgressPct%</span>
                            }
                        </div>
                    </Header>
                    <ChildContent>
                    <div class="flex-1 min-h-0 overflow-y-auto">
                    @if (!_project.PlanPhases.Any())
                    {
                        <div class="px-6 py-10 text-center">
                            <div class="inline-flex size-12 items-center justify-center rounded-2xl bg-gray-50 dark:bg-white/5 mb-3">
                                <svg class="size-5 text-gray-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
                                </svg>
                            </div>
                            <p class="text-sm font-semibold text-gray-900 dark:text-white">No phases yet</p>
                            <p class="text-xs text-gray-400 dark:text-neutral-500 mt-1">Add phases on the Edit page to give the client a roadmap.</p>
                        </div>
                    }
                    else
                    {
                        <ul role="list" class="divide-y divide-gray-100 dark:divide-white/5">
                            @foreach (var phase in _project.PlanPhases.OrderBy(ph => ph.Order))
                            {
                                <li class="px-6 py-4">
                                    <div class="flex items-start gap-3">
                                        <div class="flex-none flex size-7 items-center justify-center rounded-full bg-gray-100 dark:bg-white/10 mt-0.5">
                                            @if (phase.Status == PhaseStatus.Completed)
                                            {
                                                <svg class="size-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                                                </svg>
                                            }
                                            else
                                            {
                                                <span class="text-xs font-bold text-gray-400 dark:text-neutral-500">@phase.Order</span>
                                            }
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex flex-wrap items-center gap-2 mb-0.5">
                                                <span class="text-sm font-semibold text-gray-900 dark:text-white">@phase.Title</span>
                                                <StatusBadge CssClasses="@BadgeHelpers.PhaseStatusBadge(phase.Status)"
                                                             Dot="@BadgeHelpers.PhaseStatusDotColor(phase.Status)"
                                                             Label="@BadgeHelpers.PhaseStatusLabel(phase.Status)" />
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(phase.ShortLabel))
                                            {
                                                <span class="text-xs text-gray-400 dark:text-neutral-500">@phase.ShortLabel</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(phase.Notes))
                                            {
                                                <p class="mt-1.5 text-sm text-gray-600 dark:text-neutral-300 leading-relaxed">@phase.Notes</p>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(phase.ImportantInformation))
                                            {
                                                <div class="mt-2 flex items-start gap-1.5 rounded-lg bg-amber-50 dark:bg-amber-400/10 px-3 py-2">
                                                    <svg class="size-3.5 text-amber-500 flex-none mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                                                    </svg>
                                                    <p class="text-xs text-amber-700 dark:text-amber-400">@phase.ImportantInformation</p>
                                                </div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(phase.Dependencies))
                                            {
                                                <p class="mt-1.5 text-xs text-gray-400 dark:text-neutral-500">
                                                    <span class="font-semibold">Blockers:</span> @phase.Dependencies
                                                </p>
                                            }
                                            @if (phase.TargetCompletionDate.HasValue)
                                            {
                                                <p class="mt-1 text-xs text-gray-400 dark:text-neutral-500">
                                                    Target: @phase.TargetCompletionDate.Value.ToLocalTime().ToString("d MMM yyyy")
                                                </p>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(phase.InternalNotes))
                                            {
                                                <div class="mt-2 rounded-lg border border-dashed border-gray-200 dark:border-white/10 px-3 py-2">
                                                    <p class="text-xs text-gray-400 dark:text-neutral-500">
                                                        <span class="font-semibold uppercase tracking-wider">Admin only:</span> @phase.InternalNotes
                                                    </p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    </div>
                    </ChildContent>
                </CardSection>

                <!-- Timeline (read-only, admin view incl. internal) -->
                <CardSection Class="flex flex-col h-[28rem]">
                    <Header>
                        <div class="flex items-center justify-between">
                            <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Timeline</h2>
                            <div class="flex items-center gap-3">
                                <a href="@($"/Admin/Projects/{Id}/Documents")"
                                   class="text-sm font-semibold text-accent hover:opacity-80 transition-opacity">Documents →</a>
                                <a href="@($"/Admin/Projects/{Id}/Notes")"
                                   class="text-sm font-semibold text-accent hover:opacity-80 transition-opacity">Manage notes →</a>
                            </div>
                        </div>
                    </Header>
                    <ChildContent>
                    <div class="flex-1 min-h-0 overflow-y-auto">
                        <ProjectTimeline Events="@_project.TimelineEvents.ToList()"
                                         Audience="TimelineAudience.Admin"
                                         Max="20"
                                         EmptyText="No activity yet." />
                    </div>
                    </ChildContent>
                </CardSection>

                <!-- Invoices (read-only summary) -->
                <CardSection Class="flex flex-col h-[28rem]">
                    <Header>
                        <div class="flex items-center justify-between">
                            <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Invoices</h2>
                            <a href="@($"/Admin/Clients/{_project.ClientId}/Invoices?from={Id}")"
                               class="text-sm font-semibold text-accent hover:opacity-80 transition-opacity">Manage →</a>
                        </div>
                    </Header>
                    <ChildContent>
                    <div class="flex-1 min-h-0 overflow-y-auto">
                    @if (!_project.Invoices.Any())
                    {
                        <div class="px-6 py-8 text-center">
                            <p class="text-sm text-gray-400 dark:text-neutral-500">No invoices yet.</p>
                        </div>
                    }
                    else
                    {
                        <ul role="list" class="divide-y divide-gray-100 dark:divide-white/5">
                            @foreach (var inv in _project.Invoices.OrderByDescending(i => i.IssuedAt))
                            {
                                <li class="px-6 py-4 flex items-start justify-between gap-2">
                                    <div class="min-w-0">
                                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@inv.Title</p>
                                        <p class="text-xs text-gray-500 dark:text-neutral-400">
                                            @inv.Currency @inv.Amount.ToString("N2") · @inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")
                                        </p>
                                        @if (_downloadUrls.TryGetValue(inv.Id, out var url) && !string.IsNullOrEmpty(url))
                                        {
                                            <a href="@url" target="_blank" rel="noopener noreferrer"
                                               class="text-xs font-medium text-accent hover:underline transition-colors">Download</a>
                                        }
                                    </div>
                                    <StatusBadge CssClasses="@BadgeHelpers.InvoiceStatusBadge(inv.Status)"
                                                 Label="@inv.Status.ToString()" />
                                </li>
                            }
                        </ul>
                    }
                    </div>
                    </ChildContent>
                </CardSection>

                @if (!string.IsNullOrWhiteSpace(_project.DeploymentNotes))
                {
                    <CardSection Title="Deployment notes" Class="flex flex-col h-[28rem]">
                        <div class="px-6 py-5 flex-1 min-h-0 overflow-y-auto">
                            <p class="text-sm text-gray-600 dark:text-neutral-300 leading-relaxed whitespace-pre-line">@_project.DeploymentNotes</p>
                        </div>
                    </CardSection>
                }
        </div>
    </div>

    <ConfirmModal IsOpen="_showDelete"
                  IsOpenChanged="@(open => _showDelete = open)"
                  Title="Delete project?"
                  ConfirmWord="@_project.Name"
                  ConfirmLabel="Delete project"
                  ConfirmingLabel="Deleting…"
                  IsBusy="_deleting"
                  OnConfirm="ConfirmDeleteAsync">
        This permanently deletes
        <span class="font-semibold text-gray-900 dark:text-white">@_project.Name</span>
        along with its invoices, notes, timeline and plan phases. This can't be undone.
    </ConfirmModal>
}
