@page "/Admin/Projects/{Id:guid}"
@attribute [Authorize(Roles = "SiteAdmin")]
@layout AdminLayout

@using FellsideDigital.Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Web.Data
@using FellsideDigital.Web.Services
@using FellsideDigital.Web.Components.Layout
@using FellsideDigital.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>@(_project?.Name ?? "Project") — Fellside Digital Admin</PageTitle>

@if (_project is null)
{
    <div class="animate-pulse space-y-6">
        <div class="h-4 w-24 rounded-md bg-gray-200 dark:bg-white/10"></div>
        <div class="h-8 w-64 rounded-lg bg-gray-200 dark:bg-white/10"></div>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            <div class="lg:col-span-2 space-y-4">
                <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-48"></div>
                <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-64"></div>
            </div>
            <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-80"></div>
        </div>
    </div>
}
else
{
    <!-- Header -->
    <div class="mb-6">
        <a href="/Admin/Projects"
           class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-3">
            <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
            Projects
        </a>
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <div class="flex flex-wrap items-center gap-3 mb-1">
                    <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">@_project.Name</h1>
                    <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium @BadgeHelpers.ProjectStatusBadge(_project.Status)">
                        <span class="size-1.5 rounded-full @BadgeHelpers.ProjectStatusDotColor(_project.Status)"></span>
                        @_project.Status.DisplayName()
                    </span>
                </div>
                <p class="text-sm text-gray-500 dark:text-neutral-400">
                    @_project.Client?.CompanyName · @_project.Client?.Email
                </p>
            </div>
            <div class="flex flex-wrap items-center gap-2 sm:justify-end">
                <PrimaryButton Color="ButtonColor.Muted" Style="ButtonStyle.Outline" Href="@($"/Admin/Projects/{Id}/PortalPreview")">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                    Preview as client
                </PrimaryButton>
                <PrimaryButton Color="ButtonColor.Muted" Style="ButtonStyle.Outline" Href="@($"/Admin/Projects/{Id}/Edit")">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                    </svg>
                    Edit project
                </PrimaryButton>
                <button type="button" @onclick="() => _showDelete = true"
                        class="inline-flex items-center gap-1.5 rounded-xl px-3.5 py-2.5 text-sm font-semibold
                               text-red-500 dark:text-red-400 ring-1 ring-inset ring-red-200 dark:ring-red-500/30
                               hover:bg-red-50 dark:hover:bg-red-500/10 hover:text-red-600 dark:hover:text-red-300
                               transition-colors">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                    Delete
                </button>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">

        <!-- Left column: details + status update + activity -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Project details -->
            <CardSection Title="Project details">
                <dl class="divide-y divide-gray-100 dark:divide-white/5">
                    <div class="grid grid-cols-2 sm:grid-cols-@(_project.TargetLaunchDate.HasValue ? "3" : "2")">
                        <div class="px-6 py-4">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Type</dt>
                            <dd class="text-sm text-gray-900 dark:text-white">@_project.Type</dd>
                        </div>
                        <div class="px-6 py-4 border-l border-gray-100 dark:border-white/5">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Created</dt>
                            <dd class="text-sm text-gray-900 dark:text-white">@_project.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</dd>
                        </div>
                        @if (_project.TargetLaunchDate.HasValue)
                        {
                            <div class="px-6 py-4 border-l border-gray-100 dark:border-white/5">
                                <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Target launch</dt>
                                <dd class="text-sm text-gray-900 dark:text-white">@_project.TargetLaunchDate.Value.ToLocalTime().ToString("d MMM yyyy")</dd>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(_project.PreviewUrl))
                    {
                        <div class="px-6 py-4">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Preview URL</dt>
                            <dd class="text-sm">
                                <a href="@_project.PreviewUrl" target="_blank" rel="noopener"
                                   class="text-accent hover:underline break-all">@_project.PreviewUrl</a>
                            </dd>
                        </div>
                    }
                    <div class="px-6 py-4">
                        <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Description</dt>
                        <dd class="text-sm text-gray-700 dark:text-neutral-300 leading-relaxed">@_project.Description</dd>
                    </div>
                    @if (!string.IsNullOrEmpty(_project.DeploymentNotes))
                    {
                        <div class="px-6 py-4">
                            <dt class="text-xs font-semibold text-gray-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Deployment notes</dt>
                            <dd class="text-sm text-gray-700 dark:text-neutral-300 leading-relaxed">@_project.DeploymentNotes</dd>
                        </div>
                    }
                </dl>
            </CardSection>

            <!-- Project plan -->
            @if (_project.PlanPhases.Any())
            {
                <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm overflow-hidden">
                    <div class="px-6 py-5 border-b border-gray-100 dark:border-white/5 flex items-center justify-between">
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Project plan</h2>
                        <span class="text-xs text-gray-400 dark:text-neutral-500">@_project.PlanPhases.Count phase@(_project.PlanPhases.Count == 1 ? "" : "s")</span>
                    </div>

                    <!-- Progress bar -->
                    @{
                        var completedCount = _project.PlanPhases.Count(ph => ph.Status == PhaseStatus.Completed);
                        var progressPct = _project.PlanPhases.Count > 0
                            ? (int)Math.Round((double)completedCount / _project.PlanPhases.Count * 100)
                            : 0;
                    }
                    <div class="px-6 py-3 border-b border-gray-100 dark:border-white/5">
                        <div class="flex items-center justify-between mb-1.5">
                            <span class="text-xs text-gray-500 dark:text-neutral-400">@completedCount of @_project.PlanPhases.Count phases complete</span>
                            <span class="text-xs font-semibold text-gray-900 dark:text-white">@progressPct%</span>
                        </div>
                        <div class="h-1.5 w-full rounded-full bg-gray-100 dark:bg-white/10">
                            <div class="h-1.5 rounded-full bg-accent transition-all" style="width: @progressPct%"></div>
                        </div>
                    </div>

                    <!-- Phase list -->
                    <ul role="list" class="divide-y divide-gray-100 dark:divide-white/5">
                        @foreach (var phase in _project.PlanPhases.OrderBy(ph => ph.Order))
                        {
                            <li class="px-6 py-4">
                                <div class="flex items-start gap-3">
                                    <!-- Order + status dot -->
                                    <div class="flex-none flex size-7 items-center justify-center rounded-full bg-gray-100 dark:bg-white/10 mt-0.5">
                                        @if (phase.Status == PhaseStatus.Completed)
                                        {
                                            <svg class="size-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <span class="text-xs font-bold text-gray-400 dark:text-neutral-500">@phase.Order</span>
                                        }
                                    </div>

                                    <div class="flex-1 min-w-0">
                                        <div class="flex flex-wrap items-center gap-2 mb-0.5">
                                            <span class="text-sm font-semibold text-gray-900 dark:text-white">@phase.Title</span>
                                            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium @BadgeHelpers.PhaseStatusBadge(phase.Status)">
                                                <span class="size-1.5 rounded-full @BadgeHelpers.PhaseStatusDotColor(phase.Status)"></span>
                                                @BadgeHelpers.PhaseStatusLabel(phase.Status)
                                            </span>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(phase.ShortLabel))
                                        {
                                            <span class="text-xs text-gray-400 dark:text-neutral-500">@phase.ShortLabel</span>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(phase.Notes))
                                        {
                                            <p class="mt-1.5 text-sm text-gray-600 dark:text-neutral-300 leading-relaxed">@phase.Notes</p>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(phase.ImportantInformation))
                                        {
                                            <div class="mt-2 flex items-start gap-1.5 rounded-lg bg-amber-50 dark:bg-amber-400/10 px-3 py-2">
                                                <svg class="size-3.5 text-amber-500 flex-none mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                                                </svg>
                                                <p class="text-xs text-amber-700 dark:text-amber-400">@phase.ImportantInformation</p>
                                            </div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(phase.Dependencies))
                                        {
                                            <p class="mt-1.5 text-xs text-gray-400 dark:text-neutral-500">
                                                <span class="font-semibold">Blockers:</span> @phase.Dependencies
                                            </p>
                                        }

                                        @if (phase.TargetCompletionDate.HasValue)
                                        {
                                            <p class="mt-1 text-xs text-gray-400 dark:text-neutral-500">
                                                Target: @phase.TargetCompletionDate.Value.ToLocalTime().ToString("d MMM yyyy")
                                            </p>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(phase.InternalNotes))
                                        {
                                            <div class="mt-2 rounded-lg border border-dashed border-gray-200 dark:border-white/10 px-3 py-2">
                                                <p class="text-xs text-gray-400 dark:text-neutral-500">
                                                    <span class="font-semibold uppercase tracking-wider">Admin only:</span> @phase.InternalNotes
                                                </p>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            <!-- Post status update -->
            <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm p-6">
                <h2 class="text-sm font-semibold text-gray-900 dark:text-white mb-5">Post update to client</h2>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-neutral-300 mb-1.5">
                            Change status
                            <span class="ml-1 text-xs font-normal text-gray-400 dark:text-neutral-500">(optional)</span>
                        </label>
                        <select @bind="_newStatus" class="@InputClass">
                            <option value="">— Keep current status —</option>
                            @foreach (var s in Enum.GetValues<ProjectStatus>())
                            {
                                <option value="@s">@s.DisplayName()</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-neutral-300 mb-1.5">
                            Message <span class="text-red-500">*</span>
                        </label>
                        <textarea @bind="_updateMessage" rows="3"
                                  placeholder="What's the latest update for this client?"
                                  class="@($"{InputClass} resize-none")"></textarea>
                    </div>
                    <div class="flex justify-end">
                        <SpinnerButton IsLoading="@_postingUpdate"
                                       LoadingText="Posting…"
                                       Disabled="@string.IsNullOrWhiteSpace(_updateMessage)"
                                       OnClick="PostUpdateAsync">
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                            </svg>
                            <span>Post update</span>
                        </SpinnerButton>
                    </div>
                </div>
            </div>

            <!-- Activity timeline -->
            <div class="rounded-2xl border border-gray-200/80 dark:border-white/5 bg-white dark:bg-neutral-900 shadow-sm p-6">
                <h2 class="text-sm font-semibold text-gray-900 dark:text-white mb-5">Activity</h2>
                @if (!_project.StatusUpdates.Any())
                {
                    <div class="py-4 text-center">
                        <p class="text-sm text-gray-400 dark:text-neutral-500">No updates posted yet.</p>
                    </div>
                }
                else
                {
                    <ul role="list" class="space-y-5">
                        @foreach (var update in _project.StatusUpdates.OrderByDescending(u => u.CreatedAt))
                        {
                            <li class="relative flex gap-x-4">
                                <div class="absolute top-6 left-[11px] bottom-0 w-px bg-gray-200 dark:bg-white/10 last:hidden"></div>
                                <div class="relative flex size-6 flex-none items-center justify-center">
                                    @if (update.NewStatus.HasValue)
                                    {
                                        <div class="size-6 rounded-full bg-accent-hover flex items-center justify-center ring-1 ring-indigo-200">
                                            <div class="size-2 rounded-full bg-accent"></div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="size-6 rounded-full bg-gray-100 dark:bg-white/5 flex items-center justify-center">
                                            <div class="size-1.5 rounded-full bg-gray-300 dark:bg-white/20"></div>
                                        </div>
                                    }
                                </div>
                                <div class="flex-auto pb-5">
                                    @if (update.NewStatus.HasValue)
                                    {
                                        <p class="text-xs text-gray-500 dark:text-neutral-400 mb-0.5">
                                            Status →
                                            <span class="font-semibold text-gray-900 dark:text-white">@update.NewStatus.Value.DisplayName()</span>
                                        </p>
                                    }
                                    <p class="text-sm text-gray-700 dark:text-neutral-300">@update.Message</p>
                                    <time class="block mt-1 text-xs text-gray-400 dark:text-neutral-500">
                                        @update.CreatedAt.ToLocalTime().ToString("d MMM yyyy, HH:mm")
                                    </time>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <!-- Right column: invoices -->
        <div class="space-y-6">
            <CardSection Title="Invoices">
                @if (!_project.Invoices.Any())
                {
                    <div class="px-6 py-8 text-center">
                        <p class="text-sm text-gray-400 dark:text-neutral-500">No invoices yet.</p>
                    </div>
                }
                else
                {
                    <ul role="list" class="divide-y divide-gray-100 dark:divide-white/5">
                        @foreach (var inv in _project.Invoices.OrderByDescending(i => i.IssuedAt))
                        {
                            <li class="px-6 py-4">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <div class="min-w-0">
                                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@inv.Title</p>
                                        <p class="text-xs text-gray-500 dark:text-neutral-400">
                                            @inv.Currency @inv.Amount.ToString("N2") · @inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")
                                        </p>
                                    </div>
                                    <StatusBadge CssClasses="@BadgeHelpers.InvoiceStatusBadge(inv.Status)"
                                                 Label="@inv.Status.ToString()" />
                                </div>
                                <div class="flex items-center gap-3">
                                    <select value="@inv.Status"
                                            @onchange="e => ChangeInvoiceStatusAsync(inv.Id, e)"
                                            class="flex-1 text-xs rounded-lg border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-neutral-300 px-2 py-1.5 focus:ring-1 focus:ring-accent outline-none">
                                        @foreach (var options in EnumExtensions.ToOptions<InvoiceStatus>())
                                        {
                                            <option value="@options.Value">@options.Display</option>
                                        }
                                    </select>
                                    @if (_downloadUrls.TryGetValue(inv.Id, out var downloadUrl) && !string.IsNullOrEmpty(downloadUrl))
                                    {
                                        <a href="@downloadUrl" target="_blank" rel="noopener noreferrer"
                                           class="text-xs font-medium text-accent hover:underline transition-colors">
                                            Download
                                        </a>
                                    }
                                    <button @onclick="() => DeleteInvoiceAsync(inv.Id)"
                                            class="text-xs font-medium text-red-500 dark:text-red-400 hover:text-red-600 dark:hover:text-red-300 transition-colors">
                                        Delete
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                }

                <!-- Upload invoice -->
                <div class="border-t border-gray-100 dark:border-white/5 px-6 py-5">
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Upload invoice</h3>
                    <AlertBanner Message="@_invoiceError" Variant="error" Class="mb-3" />
                    <div class="space-y-3">
                        <input @bind="_invoiceTitle" placeholder="Invoice title *" class="@InputClass" />
                        <div class="grid grid-cols-2 gap-2">
                            <input @bind="_invoiceAmount" type="number" step="0.01" min="0" placeholder="Amount *" class="@InputClass" />
                            <select @bind="_invoiceCurrency" class="@InputClass">
                                <option value="GBP">GBP £</option>
                                <option value="USD">USD $</option>
                                <option value="EUR">EUR €</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1.5">Due date (optional)</label>
                            <input @bind="_invoiceDueDate" type="date" class="@InputClass" />
                        </div>
                        <div class="rounded-xl border-2 border-dashed border-gray-200 dark:border-white/10 p-4 text-center hover:border-accent-hover transition-colors">
                            <InputFile OnChange="OnFileSelected" accept=".pdf,.png,.jpg,.jpeg"
                                       class="block w-full text-xs text-gray-500 dark:text-neutral-400
                                              file:mr-3 file:rounded-lg file:border-0
                                              file:bg-accent-hover
                                              file:px-3 file:py-1.5 file:text-xs file:font-semibold
                                              file:text-accent
                                              hover:file:opacity-90 cursor-pointer" />
                            <p class="mt-2 text-xs text-gray-400 dark:text-neutral-500">PDF, PNG or JPG — max 10 MB</p>
                        </div>
                        <SpinnerButton IsLoading="@_uploadingInvoice"
                                       LoadingText="Uploading…"
                                       Disabled="@(_selectedFile is null || string.IsNullOrWhiteSpace(_invoiceTitle))"
                                       OnClick="UploadInvoiceAsync"
                                       FullWidth="true">
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                            </svg>
                            <span>Upload invoice</span>
                        </SpinnerButton>
                    </div>
                </div>
            </CardSection>
        </div>
    </div>
}
