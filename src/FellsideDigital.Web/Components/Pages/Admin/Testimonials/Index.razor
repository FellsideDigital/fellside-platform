@page "/Admin/Testimonials"
@attribute [Authorize(Roles = "SiteAdmin")]
@layout AdminLayout

@using FellsideDigital.Domain.Enums
@using FellsideDigital.UI.Layout
@using Microsoft.AspNetCore.Authorization
@using FellsideDigital.Web.Data
@using FellsideDigital.Web.Components.Layout
@using FellsideDigital.Web.Components.Shared

<PageTitle>Testimonials — Fellside Digital Admin</PageTitle>

<PageHeader Eyebrow="Admin" Title="Testimonials"
            Description="Review client testimonials. Approved ones appear on the public site." />

@if (_testimonials is null)
{
    <div class="animate-pulse space-y-3">
        <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-12"></div>
        @for (int i = 0; i < 4; i++)
        {
            <div class="rounded-xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-16"></div>
        }
    </div>
}
else if (_testimonials.Count == 0)
{
    <EmptyState Padding="p-14"
                IconContainerClass="size-12 rounded-2xl mb-4"
                Title="No testimonials yet"
                Subtitle="When a client submits a testimonial from their portal, it will appear here for review.">
        <Icon>
            <svg class="size-6 text-gray-400 dark:text-neutral-500" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
        </Icon>
    </EmptyState>
}
else
{
    <CardSection OverflowHidden="false">
        <table class="@TableStyles.Table">
            <thead>
                <tr class="@TableStyles.HeadRow">
                    <Th>Client</Th>
                    <Th>Rating</Th>
                    <Th Class="hidden md:table-cell">Testimonial</Th>
                    <Th>Status</Th>
                    <Th Right>Actions</Th>
                </tr>
            </thead>
            <tbody class="@TableStyles.Body">
                @foreach (var t in _testimonials)
                {
                    <tr class="@TableStyles.Row">
                        <Td>
                            <div>
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">@t.AuthorName</p>
                                <p class="text-xs text-gray-500 dark:text-neutral-400">@t.AuthorRole</p>
                            </div>
                        </Td>
                        <Td>
                            <div class="flex gap-0.5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <svg class="size-4 @(i <= t.Rating ? "text-accent" : "text-slate-200 dark:text-neutral-700")"
                                         viewBox="0 0 20 20" fill="currentColor">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                }
                            </div>
                        </Td>
                        <Td Class="hidden md:table-cell">
                            <p class="text-sm text-gray-600 dark:text-neutral-300 max-w-md line-clamp-3">"@t.Quote"</p>
                        </Td>
                        <Td>
                            <StatusBadge CssClasses="@BadgeHelpers.TestimonialStatusBadge(t.Status)"
                                         Label="@t.Status.ToString()" />
                        </Td>
                        <Td Class="relative overflow-visible text-right align-top">
                            <details class="relative inline-block text-left group [&[open]]:z-[9999]">
                                <summary class="inline-flex list-none cursor-pointer items-center justify-center rounded-lg p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-700 dark:text-neutral-400 dark:hover:bg-white/5 dark:hover:text-white transition-colors">
                                    <span class="sr-only">Open actions</span>
                                    <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 12a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm5.25 0a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm5.25 0a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z" />
                                    </svg>
                                </summary>

                                <div class="absolute right-0 z-[9999] mt-2 w-44 origin-top-right rounded-xl border border-gray-200 bg-white p-1.5 shadow-2xl ring-1 ring-black/5 dark:border-white/10 dark:bg-neutral-900 dark:ring-white/10">
                                    @if (t.Status != TestimonialStatus.Approved)
                                    {
                                        <button @onclick="() => ApproveAsync(t.Id)"
                                                class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-medium text-emerald-600 hover:bg-emerald-50 dark:text-emerald-400 dark:hover:bg-emerald-400/10 transition-colors">
                                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                            </svg>
                                            Approve
                                        </button>
                                    }
                                    @if (t.Status != TestimonialStatus.Rejected)
                                    {
                                        <button @onclick="() => RejectAsync(t.Id)"
                                                class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-medium text-amber-600 hover:bg-amber-50 dark:text-amber-400 dark:hover:bg-amber-400/10 transition-colors">
                                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                                            </svg>
                                            Reject
                                        </button>
                                    }
                                    <button @onclick="() => DeleteAsync(t.Id)"
                                            class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-sm font-medium text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-400/10 transition-colors">
                                        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                        </svg>
                                        Delete
                                    </button>
                                </div>
                            </details>
                        </Td>
                    </tr>
                }
            </tbody>
        </table>
    </CardSection>
}
