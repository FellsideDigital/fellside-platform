@page "/Admin/Clients/{ClientId}/Invoices"
@attribute [Authorize(Roles = "SiteAdmin")]
@layout AdminLayout

@using FellsideDigital.Domain.Enums
@using FellsideDigital.Domain.Extensions
@using Microsoft.AspNetCore.Authorization
@using FellsideDigital.Web.Components.Layout
@using FellsideDigital.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Invoices — Fellside Digital Admin</PageTitle>

<a href="@_backHref"
   class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-3">
    <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    Back to project
</a>

<PageHeader Eyebrow="Client" Title="Invoices" Description="@_clientLine" />

@if (_loading)
{
    <div class="animate-pulse space-y-3">
        <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-24"></div>
        <div class="rounded-2xl border border-gray-200 dark:border-white/5 bg-white dark:bg-neutral-900 h-48"></div>
    </div>
}
else
{
    <!-- Summary -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3.5 mb-5">
        <KpiCard Eyebrow="Invoiced"
                 Value="@($"£{_invoices.Sum(i => i.Amount):N0}")"
                 Sub="@($"{_invoices.Count} invoice{(_invoices.Count == 1 ? "" : "s")}")"
                 IconPath="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"
                 Tone="blue" />
        <KpiCard Eyebrow="Outstanding"
                 Value="@($"£{_outstandingTotal:N0}")"
                 Sub="@_outstandingSub"
                 IconPath="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"
                 Tone="rose" />
        <KpiCard Eyebrow="Paid"
                 Value="@($"£{_paidTotal:N0}")"
                 Sub="@($"{_invoices.Count(i => i.Status == InvoiceStatus.Paid)} settled")"
                 IconPath="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                 Tone="emerald" />
    </div>

    <!-- Invoice list -->
    <CardSection Title="All invoices" Class="mb-5">
        @if (_invoices.Count == 0)
        {
            <div class="px-6 py-10 text-center">
                <p class="text-sm text-gray-400 dark:text-neutral-500">No invoices for this client yet.</p>
            </div>
        }
        else
        {
            <table class="@TableStyles.Table">
                <thead>
                    <tr class="@TableStyles.HeadRow">
                        <Th>Invoice</Th>
                        <Th Class="hidden md:table-cell">Project</Th>
                        <Th>Amount</Th>
                        <Th>Status</Th>
                        <Th Right>Actions</Th>
                    </tr>
                </thead>
                <tbody class="@TableStyles.Body">
                    @foreach (var inv in _invoices)
                    {
                        <tr class="@TableStyles.Row">
                            <Td>
                                <p class="text-sm font-semibold text-gray-900 dark:text-white">@inv.Title</p>
                                <p class="text-xs text-gray-500 dark:text-neutral-400">@inv.IssuedAt.ToLocalTime().ToString("d MMM yyyy")</p>
                            </Td>
                            <Td Class="hidden md:table-cell">
                                <span class="text-sm text-gray-700 dark:text-neutral-300">@inv.Project?.Name</span>
                            </Td>
                            <Td>
                                <span class="text-sm text-gray-900 dark:text-white">@inv.Currency @inv.Amount.ToString("N2")</span>
                            </Td>
                            <Td>
                                <select value="@inv.Status"
                                        @onchange="e => ChangeStatusAsync(inv.Id, e)"
                                        class="text-xs rounded-lg border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-neutral-300 px-2 py-1.5 focus:ring-1 focus:ring-accent outline-none">
                                    @foreach (var opt in EnumExtensions.ToOptions<InvoiceStatus>())
                                    {
                                        <option value="@opt.Value">@opt.Display</option>
                                    }
                                </select>
                            </Td>
                            <Td>
                                <div class="flex items-center justify-end gap-3">
                                    @if (_downloadUrls.TryGetValue(inv.Id, out var url) && !string.IsNullOrEmpty(url))
                                    {
                                        <a href="@url" target="_blank" rel="noopener noreferrer"
                                           class="text-xs font-medium text-accent hover:underline transition-colors">Download</a>
                                    }
                                    <button @onclick="() => DeleteInvoiceAsync(inv.Id)"
                                            class="text-xs font-medium text-red-500 dark:text-red-400 hover:text-red-600 dark:hover:text-red-300 transition-colors">
                                        Delete
                                    </button>
                                </div>
                            </Td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </CardSection>

    <!-- Add invoice -->
    <CardSection Title="Add invoice">
        <div class="px-6 py-5">
            <AlertBanner Message="@_error" Variant="error" Class="mb-3" />
            @if (_projects.Count == 0)
            {
                <p class="text-sm text-gray-400 dark:text-neutral-500">This client has no projects to attach an invoice to.</p>
            }
            else
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div class="sm:col-span-2">
                        <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1.5">Project *</label>
                        <select @bind="_selectedProjectId" class="@InputClass">
                            <option value="">— Select project —</option>
                            @foreach (var p in _projects)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1.5">Title *</label>
                        <input @bind="_title" placeholder="e.g. Deposit invoice" class="@InputClass" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1.5">Amount *</label>
                        <input @bind="_amount" type="number" step="0.01" min="0" placeholder="0.00" class="@InputClass" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1.5">Currency</label>
                        <select @bind="_currency" class="@InputClass">
                            <option value="GBP">GBP £</option>
                            <option value="USD">USD $</option>
                            <option value="EUR">EUR €</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1.5">Due date (optional)</label>
                        <input @bind="_dueDate" type="date" class="@InputClass" />
                    </div>
                    <div class="sm:col-span-2">
                        <div class="rounded-xl border-2 border-dashed border-gray-200 dark:border-white/10 p-4 text-center hover:border-accent transition-colors">
                            <InputFile OnChange="OnFileSelected" accept=".pdf,.png,.jpg,.jpeg"
                                       class="block w-full text-xs text-gray-500 dark:text-neutral-400
                                              file:mr-3 file:rounded-lg file:border-0 file:bg-accent
                                              file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-white
                                              hover:file:opacity-90 cursor-pointer" />
                            <p class="mt-2 text-xs text-gray-400 dark:text-neutral-500">PDF, PNG or JPG — max 10 MB</p>
                        </div>
                    </div>
                    <div class="sm:col-span-2 flex justify-end">
                        <SpinnerButton IsLoading="@_uploading"
                                       LoadingText="Uploading…"
                                       Disabled="@(_selectedFile is null || string.IsNullOrWhiteSpace(_selectedProjectId) || string.IsNullOrWhiteSpace(_title))"
                                       OnClick="AddInvoiceAsync">
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                            </svg>
                            <span>Add invoice</span>
                        </SpinnerButton>
                    </div>
                </div>
            }
        </div>
    </CardSection>
}
