@page "/website-design/{Town}"
@using FellsideDigital.Web.Components.Pages
@using FellsideDigital.Web.Components.Pages.System

@if (_location is null)
{
    <PageTitle>Page not found · Fellside Digital</PageTitle>
    <NotFound />
}
else
{
    var loc = _location;

    <PageTitle>@loc.MetaTitle</PageTitle>

    <SeoHead Title="@loc.MetaTitle"
             Description="@loc.MetaDescription"
             CanonicalUrl="@($"https://fellsidedigital.co.uk/website-design/{loc.Slug}")" />

    <HeadContent>
        <script type="application/ld+json">@((MarkupString)LocationData.ServiceJson(loc))</script>
        <script type="application/ld+json">@((MarkupString)LocationData.BreadcrumbJson(loc))</script>
        <script type="application/ld+json">@((MarkupString)LocationData.FaqJson(loc))</script>
    </HeadContent>

    <div class="flex flex-col w-full max-w-full overflow-x-hidden
                bg-white dark:bg-neutral-950 text-slate-900 dark:text-white
                transition-colors duration-300">

        <!-- ── HERO ──────────────────────────────────────────────────────────── -->
        <section class="relative overflow-hidden py-24 sm:py-32 px-6 bg-white dark:bg-neutral-950">
            <div class="grain-overlay" aria-hidden="true"></div>
            <div class="hero-aura" aria-hidden="true">
                <div class="hero-aura-blob"></div>
            </div>

            <div class="relative z-10 max-w-3xl mx-auto">
                <!-- Breadcrumb -->
                <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-1.5 text-xs font-medium text-slate-400 dark:text-neutral-500">
                    <a href="/" class="hover:text-accent transition-colors">Home</a>
                    <span>/</span>
                    <a href="/websites" class="hover:text-accent transition-colors">Website Design</a>
                    <span>/</span>
                    <span class="text-slate-600 dark:text-neutral-300">@loc.Town</span>
                </nav>

                <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">
                    @loc.HeroKicker
                </p>
                <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-balance
                           text-slate-900 dark:text-white mb-6">
                    Website design &amp; web development in
                    <span class="text-accent">@loc.Town</span>
                </h1>
                <p class="text-lg text-slate-600 dark:text-neutral-300 leading-relaxed mb-5">
                    @loc.Lead
                </p>
                <p class="text-base text-slate-500 dark:text-neutral-400 leading-relaxed mb-8">
                    @loc.LocalContext
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="/contact"
                       class="rounded-xl bg-accent px-6 py-3 text-sm font-semibold
                              text-white shadow-sm hover:opacity-90 transition-all text-center">
                        Get a fixed-price quote
                    </a>
                    <a href="/websites"
                       class="rounded-xl px-6 py-3 text-sm font-semibold text-center
                              text-slate-700 dark:text-neutral-200
                              ring-1 ring-slate-200 dark:ring-white/10
                              hover:bg-slate-50 dark:hover:bg-white/5 transition-all">
                        See what we build
                    </a>
                </div>
                <p class="mt-6 text-sm text-slate-400 dark:text-neutral-500">@loc.TravelNote</p>
            </div>
        </section>

        <!-- ── AREAS + SECTORS ───────────────────────────────────────────────── -->
        <section class="py-16 px-6 bg-slate-50 dark:bg-neutral-900 transition-colors duration-300">
            <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-10">
                <div>
                    <p class="text-xs font-medium uppercase tracking-widest text-accent mb-4">Areas we cover near @loc.Town</p>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var area in loc.NearbyAreas)
                        {
                            <span class="rounded-full px-3 py-1 text-sm font-medium
                                         bg-white text-slate-600 ring-1 ring-slate-200
                                         dark:bg-neutral-800 dark:text-neutral-300 dark:ring-white/5">@area</span>
                        }
                    </div>
                </div>
                <div>
                    <p class="text-xs font-medium uppercase tracking-widest text-accent mb-4">@loc.Town businesses we work with</p>
                    <ul class="space-y-2">
                        @foreach (var sector in loc.LocalSectors)
                        {
                            <li class="flex items-center gap-2.5 text-sm text-slate-600 dark:text-neutral-300">
                                <span class="size-1.5 rounded-full bg-accent flex-shrink-0"></span>
                                @sector
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </section>

        <!-- ── WHAT WE BUILD ─────────────────────────────────────────────────── -->
        <section class="py-20 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
            <div class="max-w-5xl mx-auto">
                <SectionHeader Label="What we do"
                               Heading="@($"Web development for {loc.Town}, done properly.")"
                               Description="Every site is hand-coded for speed and built around your business — no templates, no page builders, no hand-offs." />

                <div class="mt-12 grid sm:grid-cols-3 gap-6">
                    <div class="rounded-2xl bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5 p-6">
                        <h3 class="text-base font-semibold text-slate-900 dark:text-neutral-100 mb-2">Custom website design</h3>
                        <p class="text-sm text-slate-500 dark:text-neutral-400 leading-relaxed">Fast, bespoke marketing sites built to rank in local search and convert @loc.Town visitors into enquiries.</p>
                    </div>
                    <div class="rounded-2xl bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5 p-6">
                        <h3 class="text-base font-semibold text-slate-900 dark:text-neutral-100 mb-2">Web apps &amp; e-commerce</h3>
                        <p class="text-sm text-slate-500 dark:text-neutral-400 leading-relaxed">Online stores, booking systems, client portals and dashboards — proper software, not just pages.</p>
                    </div>
                    <div class="rounded-2xl bg-white dark:bg-neutral-900 ring-1 ring-slate-200 dark:ring-white/5 p-6">
                        <h3 class="text-base font-semibold text-slate-900 dark:text-neutral-100 mb-2">Support &amp; hosting</h3>
                        <p class="text-sm text-slate-500 dark:text-neutral-400 leading-relaxed">Retainer packages covering hosting, updates, backups and monitoring, so your site keeps performing.</p>
                    </div>
                </div>

                <div class="mt-10 text-center">
                    <a href="/websites" class="text-sm font-semibold text-accent hover:text-accent/70 transition-colors">
                        Full website services <span aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- ── FAQ ───────────────────────────────────────────────────────────── -->
        <section class="py-20 px-6 bg-slate-50 dark:bg-neutral-900 transition-colors duration-300">
            <div class="max-w-3xl mx-auto">
                <SectionHeader Label="FAQs"
                               Heading="@($"Web design in {loc.Town} — common questions")"
                               Description="" />
                <div class="mt-10 flex flex-col divide-y divide-slate-200 dark:divide-white/5">
                    @foreach (var faq in loc.Faqs)
                    {
                        <div class="py-6">
                            <h3 class="text-base font-semibold text-slate-900 dark:text-neutral-100 mb-2">@faq.Question</h3>
                            <p class="text-sm text-slate-500 dark:text-neutral-400 leading-relaxed">@faq.Answer</p>
                        </div>
                    }
                </div>
            </div>
        </section>

        <!-- ── OTHER AREAS (internal links) ──────────────────────────────────── -->
        <section class="py-16 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
            <div class="max-w-5xl mx-auto text-center">
                <p class="text-xs font-medium uppercase tracking-widest text-slate-400 dark:text-neutral-500 mb-6">
                    We also design websites across Cumbria
                </p>
                <div class="flex flex-wrap justify-center gap-3">
                    @foreach (var other in LocationData.All.Where(l => l.Slug != loc.Slug))
                    {
                        <a href="/website-design/@other.Slug"
                           class="rounded-xl px-4 py-2 text-sm font-medium
                                  text-slate-700 dark:text-neutral-200
                                  ring-1 ring-slate-200 dark:ring-white/10
                                  hover:bg-slate-50 dark:hover:bg-white/5 hover:text-accent transition-all">
                            Website design in @other.Town
                        </a>
                    }
                </div>
            </div>
        </section>

        <!-- ── CTA ───────────────────────────────────────────────────────────── -->
        <section class="py-24 px-6 relative overflow-hidden bg-white dark:bg-neutral-950 transition-colors duration-300">
            <div class="hero-glow opacity-20" aria-hidden="true"></div>
            <div class="relative z-10 max-w-2xl mx-auto text-center space-y-6">
                <h2 class="text-4xl md:text-5xl font-semibold tracking-tight text-balance text-slate-900 dark:text-white">
                    Need a website in @loc.Town?
                </h2>
                <p class="text-base text-slate-500 dark:text-neutral-400">
                    Tell us about your project and we'll come back with a clear plan and a fixed price — no obligation.
                </p>
                <div class="flex justify-center pt-2">
                    <a href="/contact"
                       class="rounded-xl bg-accent px-7 py-3 text-sm font-semibold
                              text-white shadow-lg hover:opacity-90 transition-all">
                        Start your project
                    </a>
                </div>
            </div>
        </section>

    </div>
}

@code {
    [Parameter] public string? Town { get; set; }

    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private Location? _location;

    protected override void OnParametersSet()
    {
        _location = LocationData.FindBySlug(Town);

        // Return a real 404 for unknown slugs during server prerender (SEO-correct).
        if (_location is null && HttpContext is not null)
        {
            HttpContext.Response.StatusCode = 404;
        }
    }
}
