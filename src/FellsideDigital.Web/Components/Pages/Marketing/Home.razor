@page "/"
@using FellsideDigital.Web.Services
@inject IHeroProjectService HeroProjectService
@inject IProjectService ProjectService

<PageTitle>Web Developer Cumbria &amp; Lake District | Fellside Digital</PageTitle>

<SeoHead Title="Web Developer Cumbria &amp; Lake District | Fellside Digital"
         Description="Bespoke web developer based in Keswick, Cumbria. Premium websites and intelligent automation for businesses across the Lake District and UK. Fixed prices, founder-led."
         CanonicalUrl="https://fellsidedigital.co.uk/" />

<HeadContent>
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "WebSite",
      "@@id": "https://fellsidedigital.co.uk/#website",
      "name": "Fellside Digital",
      "url": "https://fellsidedigital.co.uk",
      "description": "Bespoke web development and intelligent automation, based in Keswick, Cumbria. Serving businesses across the Lake District and UK-wide.",
      "publisher": { "@@id": "https://fellsidedigital.co.uk/#business" }
    }
    </script>
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "ProfessionalService",
      "@@id": "https://fellsidedigital.co.uk/#business",
      "name": "Fellside Digital",
      "description": "Bespoke web development and intelligent business automation, based in Keswick, Cumbria. Serving businesses across the Lake District and UK-wide.",
      "url": "https://fellsidedigital.co.uk",
      "telephone": "+447484323505",
      "email": "hello@fellsidedigital.co.uk",
      "address": {
        "@@type": "PostalAddress",
        "addressLocality": "Keswick",
        "addressRegion": "Cumbria",
        "addressCountry": "GB"
      },
      "areaServed": [
        { "@@type": "Place", "name": "Cumbria" },
        { "@@type": "Place", "name": "Lake District" },
        { "@@type": "Place", "name": "United Kingdom" }
      ],
      "knowsAbout": ["Web Development", "Website Design", "Business Automation", "API Integration", "AI Automation", "Blazor", ".NET"],
      "priceRange": "££",
      "openingHoursSpecification": {
        "@@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "17:30"
      }
    }
    </script>
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "FAQPage",
      "mainEntity": [
        {
          "@@type": "Question",
          "name": "Why choose Fellside Digital?",
          "acceptedAnswer": { "@@type": "Answer", "text": "You deal directly with the developers doing the work, no account managers, no hand-offs. We keep overhead low, which means better value and a more personal service throughout." }
        },
        {
          "@@type": "Question",
          "name": "What kind of projects do you take on?",
          "acceptedAnswer": { "@@type": "Answer", "text": "We build premium websites, custom web applications, e-commerce platforms, client portals, internal dashboards, and intelligent automation systems. We work with SMEs, agencies, and non-profits across the UK." }
        },
        {
          "@@type": "Question",
          "name": "How much does a project cost?",
          "acceptedAnswer": { "@@type": "Answer", "text": "A foundational website starts from around £450. Software-driven sites and bespoke systems are scoped individually. We always provide a clear, fixed quote before any work begins." }
        },
        {
          "@@type": "Question",
          "name": "How long does a project take?",
          "acceptedAnswer": { "@@type": "Answer", "text": "Simpler sites can be delivered in 2–4 weeks. Complex software systems typically take 2–4 months. We agree a timeline upfront and keep you updated via your dedicated project portal." }
        },
        {
          "@@type": "Question",
          "name": "Do you offer ongoing support after launch?",
          "acceptedAnswer": { "@@type": "Answer", "text": "Absolutely. We offer retainer-based maintenance packages covering hosting, updates, backups, monitoring, and priority support. We build software to last." }
        }
      ]
    }
    </script>
</HeadContent>

<div class="flex flex-col w-full max-w-full overflow-x-hidden
            bg-white dark:bg-neutral-950 text-slate-900 dark:text-white
            transition-colors duration-300">

    <!-- ── HERO ──────────────────────────────────────────────────────────── -->
    <section class="grid grid-cols-1 lg:grid-cols-[1fr_1.15fr] w-full overflow-hidden lg:min-h-[970px]">

        <!-- Left panel — theme-aware -->
        <div class="bg-white dark:bg-neutral-950
                    border-b border-slate-100 dark:border-white/5
                    lg:border-b-0 lg:border-r lg:border-slate-100 lg:dark:border-white/5
                    flex flex-col justify-center
                    pt-24 pb-12 px-6 sm:px-10 xl:px-16
                    sm:pt-28 sm:pb-14
                    gap-5">

            <div class="flex items-center gap-2">
                <span class="size-2 rounded-full bg-green-400
                             shadow-[0_0_0_3px_rgba(34,197,94,0.2)]"></span>
                <span class="text-xs font-semibold text-slate-500 dark:text-neutral-500">
                    Taking on new projects
                </span>
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-[3.25rem] font-extrabold tracking-tight leading-[1.05]
                       text-slate-900 dark:text-white text-balance">
                Smarter websites.<br>
                <span class="text-accent">Smoother workflows.</span>
            </h1>

            <p class="text-base text-slate-500 dark:text-neutral-400 leading-relaxed max-w-sm text-balance">
                Bespoke websites and automation for businesses that want quality work
                and a real relationship with who's building it. No templates, no hand-offs.
            </p>

            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
                <a href="/contact"
                   class="rounded-xl bg-accent px-5 py-2.5 text-sm font-semibold
                          text-white hover:opacity-90 active:scale-95 transition-all">
                    Start a project
                </a>
                <a href="#practices"
                   class="text-sm font-semibold text-slate-500 dark:text-neutral-400
                          hover:text-accent transition-colors">
                    See what we do →
                </a>
            </div>

            <div class="flex gap-7 pt-2 border-t border-slate-100 dark:border-white/5">
                <div>
                    <p class="text-xl font-extrabold tracking-tight text-slate-900 dark:text-white">@(_projectCount)+</p>
                    <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-400 dark:text-neutral-600 mt-0.5">Projects</p>
                </div>
                <div>
                    <p class="text-xl font-extrabold tracking-tight text-slate-900 dark:text-white">5★</p>
                    <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-400 dark:text-neutral-600 mt-0.5">Reviews</p>
                </div>
                <div>
                    <p class="text-xl font-extrabold tracking-tight text-slate-900 dark:text-white">5+</p>
                    <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-400 dark:text-neutral-600 mt-0.5">Years</p>
                </div>
            </div>
        </div>

        <!-- Right panel — always dark, project carousel -->
        <div class="hero-split-right flex flex-col p-4 sm:p-5 lg:p-6 min-h-[380px]">
            <HeroProjectCarousel Projects="_heroProjects" />
        </div>

    </section>

    <!-- ── TWO PRACTICES ─────────────────────────────────────────────────── -->
    <section id="practices" class="py-20 px-6 bg-slate-50 dark:bg-neutral-900 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="What we do"
                           Heading="Two practices, one partner."
                           Description="Premium websites and intelligent automation, both done properly." />

            <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6">

                <!-- Websites card — force-light pins --accent to indigo for all children -->
                <div class="card card-cool group force-light
                            rounded-2xl bg-white dark:bg-neutral-900
                            ring-1 ring-slate-200 dark:ring-white/5">
                    <div class="p-8 sm:p-10 flex flex-col h-full">
                        <div class="flex size-11 items-center justify-center rounded-xl
                                    bg-accent/10 mb-6">
                            <svg class="size-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
                            </svg>
                        </div>
                        <p class="text-xs font-semibold uppercase tracking-widest
                                  text-accent mb-2">
                            Website Design & Development
                        </p>
                        <h3 class="text-2xl font-semibold text-slate-900 dark:text-neutral-100 mb-3">
                            Bespoke websites designed to convert
                        </h3>
                        <p class="text-base text-slate-500 dark:text-neutral-400 leading-relaxed mb-6 flex-1">
                            High-performance, beautifully crafted websites and web applications
                            built around your brand. No templates, no shortcuts — every pixel
                            is built for you.
                        </p>
                        <ul class="space-y-2.5 mb-8">
                            @foreach (var item in _websiteFeatures)
                            {
                                <li class="flex items-start gap-2.5 text-sm text-slate-500 dark:text-neutral-400">
                                    <svg class="size-4 shrink-0 mt-0.5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                    @item
                                </li>
                            }
                        </ul>
                        <a href="/websites"
                           class="inline-flex items-center gap-1.5 text-sm font-semibold
                                  text-accent
                                  group-hover:gap-3 transition-all duration-200">
                            Explore website services
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Automation card — force-dark pins --accent to orange for all children -->
                <div class="card card-warm group force-dark
                            rounded-2xl bg-white dark:bg-neutral-900
                            ring-1 ring-slate-200 dark:ring-white/5">
                    <div class="p-8 sm:p-10 flex flex-col h-full">
                        <div class="flex size-11 items-center justify-center rounded-xl
                                    bg-accent/10 mb-6">
                            <svg class="size-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                            </svg>
                        </div>
                        <p class="text-xs font-semibold uppercase tracking-widest
                                  text-accent mb-2">
                            Intelligent Automation
                        </p>
                        <h3 class="text-2xl font-semibold text-slate-900 dark:text-neutral-100 mb-3">
                            Automation that scales with your business
                        </h3>
                        <p class="text-base text-slate-500 dark:text-neutral-400 leading-relaxed mb-6 flex-1">
                            From eliminating manual processes to embedding AI into your workflows,
                            we build automation that is reliable, maintainable, and built to grow
                            with your operation.
                        </p>
                        <ul class="space-y-2.5 mb-8">
                            @foreach (var item in _automationFeatures)
                            {
                                <li class="flex items-start gap-2.5 text-sm text-slate-500 dark:text-neutral-400">
                                    <svg class="size-4 shrink-0 mt-0.5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                    @item
                                </li>
                            }
                        </ul>
                        <a href="/automation"
                           class="inline-flex items-center gap-1.5 text-sm font-semibold
                                  text-accent
                                  group-hover:gap-3 transition-all duration-200">
                            Explore automation services
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                            </svg>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- ── HOW WE WORK ────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="Process"
                           Heading="How we work."
                           Description="Founder-led, no hand-offs. The person you talk to is the person doing the work."
                           Center="true" />

            <div class="mt-12 process-rail">
                <div class="process-rail-line" aria-hidden="true"></div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                    @foreach (var (step, idx) in _processSteps.Select((s, i) => (s, i + 1)))
                    {
                        <div class="relative">
                            <div class="relative z-10 flex size-10 items-center justify-center rounded-xl mb-5
                                        bg-white dark:bg-neutral-950
                                        ring-1 ring-slate-200 dark:ring-white/10
                                        shadow-[inset_0_0_0_4px_rgba(129,140,248,0.12)] dark:shadow-[inset_0_0_0_4px_rgba(251,146,60,0.12)]">
                                <span class="text-sm font-bold text-accent">@idx</span>
                            </div>
                            <h3 class="text-base font-semibold text-slate-900 dark:text-neutral-100 mb-2">
                                @step.Title
                            </h3>
                            <p class="text-sm text-slate-500 dark:text-neutral-400 leading-relaxed">
                                @step.Description
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- ── TESTIMONIALS ───────────────────────────────────────────────────── -->
    <section id="testimonials" class="py-20 px-6 bg-slate-50 dark:bg-neutral-900 transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
            <SectionHeader Label="Client stories"
                           Heading="Proud to support businesses across Cumbria."
                           Center="true" />

            @if (_testimonials.Count == 0)
            {
                <div class="mt-12 max-w-xl mx-auto">
                    <EmptyState Padding="p-12"
                                IconContainerClass="size-12 rounded-2xl mb-4"
                                Title="No testimonials yet"
                                Subtitle="We're just getting started here — client stories will appear in this space soon.">
                        <Icon>
                            <svg class="size-6 text-gray-400 dark:text-neutral-500" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                        </Icon>
                    </EmptyState>
                </div>
            }
            else
            {
                <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
                    @foreach (var t in _testimonials)
                    {
                        <TestimonialCard Quote="@t.Quote" Name="@t.Name" Role="@t.Role" Rating="t.Rating" />
                    }
                </div>
            }
        </div>
    </section>

    <!-- ── FAQ ────────────────────────────────────────────────────────────── -->
    <section id="faq" class="py-20 px-6 bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="max-w-3xl mx-auto">
            <SectionHeader Label="FAQs"
                           Heading="Common questions."
                           Center="true" />

            <div class="mt-10 space-y-2">
                @foreach (var faq in HomeData.Faqs)
                {
                    bool isOpen = _openFaq == faq.Question;
                    <div class="rounded-xl overflow-hidden
                                ring-1 ring-slate-200 dark:ring-white/5
                                bg-slate-50 dark:bg-neutral-900">

                        <PrimaryButton OnClick="() => ToggleFaq(faq.Question)" OverrideDefaultStyles="true" Class="w-full flex items-center justify-between px-6 py-5 text-left text-sm font-medium hover:text-accent transition-colors">
                            <span>@faq.Question</span>
                            <svg class="size-4 shrink-0 ml-4 transition-transform duration-200
                                @(isOpen ? "rotate-45" : "")"
                                 fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                            </svg>
                        </PrimaryButton>

                        @if (isOpen)
                        {
                            <div class="px-6 pb-6 pt-2 text-sm leading-relaxed
                                        border-t border-slate-200 dark:border-white/5
                                        text-slate-500 dark:text-neutral-400">
                                @faq.Answer
                            </div>
                        }
                    </div>
                }
            </div>

            <p class="mt-8 text-center text-sm text-slate-500 dark:text-neutral-400">
                Still have questions?
                <a href="/contact" class="font-medium text-accent hover:underline">Let's talk.</a>
            </p>
        </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────────────── -->
    <section class="py-24 px-6 relative overflow-hidden bg-white dark:bg-neutral-950 transition-colors duration-300">
        <div class="hero-aura" aria-hidden="true">
            <div class="hero-aura-blob"></div>
        </div>
        <div class="relative z-10 max-w-2xl mx-auto text-center space-y-6">
            <p class="text-sm font-medium uppercase tracking-widest text-slate-400 dark:text-neutral-500">
                Ready to get started?
            </p>
            <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-balance text-slate-900 dark:text-white">
                Whether you need a stunning website, intelligent automation, or both!
                <span class="text-accent">Let's build something great.</span>
            </h2>
            <p class="text-base text-slate-500 dark:text-neutral-400">
                No obligation. Just a conversation about what you need.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-2">
                <PrimaryButton Href="/contact" Class="px-7 py-3">Start the conversation</PrimaryButton>
                <PrimaryButton Href="/websites" Color="ButtonColor.Muted" Style="ButtonStyle.Text">
                    See our work →
                </PrimaryButton>
            </div>
        </div>
    </section>

</div>

@code {
    private string? _openFaq;
    private List<FellsideDigital.Web.Data.ClientProject> _heroProjects = [];
    private int _projectCount;

    protected override async Task OnInitializedAsync()
    {
        _heroProjects = await HeroProjectService.GetHeroProjectsAsync();
        _projectCount = await ProjectService.GetProjectCountAsync();
        await LoadTestimonialsAsync();
    }

    private void ToggleFaq(string q) => _openFaq = _openFaq == q ? null : q;

    private static readonly string[] _websiteFeatures =
    [
        "Custom website design & development",
        "E-commerce & client portals",
        "Booking systems & bespoke dashboards",
        "Ongoing support & maintenance",
    ];

    private static readonly string[] _automationFeatures =
    [
        "Workflow & process automation",
        "API & systems integration",
        "AI-powered decision automation",
        "Data pipeline & reporting automation",
    ];

    private record ProcessStep(string Title, string Description);

    private static readonly ProcessStep[] _processSteps =
    [
        new("Discovery call", "We spend time understanding your goals and what success looks like — before a single line of code is written."),
        new("Fixed-price quote", "A clear, itemised proposal with a fixed price and timeline. No hidden fees, no scope creep."),
        new("Build & updates", "We build iteratively, keeping you updated via your dedicated project portal. You always know where things stand."),
        new("Launch & beyond", "We handle the launch and stay on hand. Most clients continue with a retainer — we build things to last."),
    ];
}
