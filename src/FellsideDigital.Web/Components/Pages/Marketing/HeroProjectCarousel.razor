@using FellsideDigital.Domain.Enums
@using FellsideDigital.UI.Components.Icons
@using FellsideDigital.Web.Data
@using FellsideDigital.UI.Enums
@inject IJSRuntime JS

@if (Projects.Count == 0)
{
    <div class="flex items-center justify-center h-full min-h-[360px]">
        <p class="text-sm font-medium text-slate-400 dark:text-slate-600">No featured projects yet.</p>
    </div>
}
else
{
    <div class="flex flex-col gap-4 h-full">

        <!-- Header row -->
        <div class="flex items-center justify-between">
            <span class="text-[10px] font-bold uppercase tracking-[0.16em] text-slate-400 dark:text-slate-500">Recent work</span>
            @if (Projects.Count > 1)
            {
                <div class="flex gap-1.5">
                    <button @onclick="Prev" aria-label="Previous project"
                            class="flex size-8 items-center justify-center rounded-lg
                                   bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700
                                   text-slate-500 dark:text-slate-400
                                   hover:text-slate-900 dark:hover:text-white
                                   hover:bg-slate-100 dark:hover:bg-slate-700
                                   shadow-sm transition-colors">
                        <Icon Name="IconName.ChevronLeft" Size="IconSize.Normal" />
                    </button>
                    <button @onclick="Next" aria-label="Next project"
                            class="flex size-8 items-center justify-center rounded-lg
                                   bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700
                                   text-slate-500 dark:text-slate-400
                                   hover:text-slate-900 dark:hover:text-white
                                   hover:bg-slate-100 dark:hover:bg-slate-700
                                   shadow-sm transition-colors">
                        <Icon Name="IconName.ChevronRight" Size="IconSize.Normal" />
                    </button>
                </div>
            }
        </div>

        <!-- Project card -->
        <div class="flex-1 rounded-2xl overflow-hidden flex flex-col
                    border border-slate-200 dark:border-slate-700/60
                    bg-white dark:bg-slate-800/50
                    shadow-lg shadow-slate-900/5 dark:shadow-black/20">
            @if (Current.Type == ProjectType.Website)
            {
                <!-- ── WEBSITE CARD ── live browser preview -->
                <div class="relative flex flex-col h-[300px] sm:h-[380px]">
                    <!-- Browser chrome -->
                    <div class="shrink-0 flex items-center gap-1.5 px-3 py-2.5
                                bg-slate-100 dark:bg-slate-900
                                border-b border-slate-200 dark:border-slate-700/60">
                        <span class="size-2.5 rounded-full bg-red-400 dark:bg-red-500/70 flex-shrink-0"></span>
                        <span class="size-2.5 rounded-full bg-yellow-400 dark:bg-yellow-500/70 flex-shrink-0"></span>
                        <span class="size-2.5 rounded-full bg-green-400 dark:bg-green-500/70 flex-shrink-0"></span>
                        <div class="flex-1 ml-2 flex items-center gap-1.5
                                    bg-white dark:bg-slate-800 rounded-md px-2.5 py-1
                                    text-[10px] font-mono text-slate-500 dark:text-slate-500
                                    border border-slate-200 dark:border-transparent">
                            <svg class="size-2.5 text-green-500 dark:text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                            </svg>
                            <span class="truncate">@(Current.HeroShowcaseUrl ?? Current.PreviewUrl ?? "—")</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Current.HeroShowcaseUrl))
                        {
                            <a href="@Current.HeroShowcaseUrl" target="_blank" rel="noopener noreferrer"
                               class="flex-shrink-0 text-slate-400 hover:text-slate-700 dark:text-slate-600 dark:hover:text-slate-400 transition-colors"
                               aria-label="Open site in new tab">
                                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                </svg>
                            </a>
                        }
                    </div>

                    <!-- Preview viewport: live iframe with screenshot/wireframe fallback -->
                    <div class="relative flex-1 overflow-hidden bg-white dark:bg-slate-900">
                        @if (!string.IsNullOrWhiteSpace(Current.PreviewUrl))
                        {
                            <iframe id="@IframeId"
                                    src="@Current.PreviewUrl"
                                    sandbox="allow-scripts allow-same-origin"
                                    loading="lazy"
                                    title="@Current.Name preview"
                                    class="absolute inset-0 w-full h-full border-0 bg-white dark:bg-slate-900"
                                    style="display:none;">
                            </iframe>
                        }

                        <!-- Fallback: screenshot or generic wireframe -->
                        <div id="@FallbackId"
                             class="absolute inset-0 flex items-center justify-center bg-white dark:bg-slate-900">
                            @if (!string.IsNullOrWhiteSpace(Current.ScreenshotPath))
                            {
                                <img src="@Current.ScreenshotPath"
                                     alt="@Current.Name screenshot"
                                     class="w-full h-full object-cover object-top" />
                            }
                            else
                            {
                                <!-- Generic wireframe placeholder -->
                                <div class="w-full h-full p-5 flex flex-col gap-3.5">
                                    <div class="h-9 rounded-lg bg-accent flex items-center px-3.5 gap-2">
                                        <div class="h-2.5 w-20 rounded bg-white/70"></div>
                                        <div class="flex gap-2 ml-auto">
                                            <div class="h-2 w-7 rounded bg-white/40"></div>
                                            <div class="h-2 w-7 rounded bg-white/40"></div>
                                            <div class="h-2 w-7 rounded bg-white/40"></div>
                                        </div>
                                    </div>
                                    <div class="flex-1 rounded-lg bg-slate-100 dark:bg-slate-800/60 flex items-center px-6 gap-5">
                                        <div class="flex flex-col gap-2.5">
                                            <div class="h-3.5 w-36 rounded bg-slate-300 dark:bg-white/40"></div>
                                            <div class="h-2.5 w-24 rounded bg-slate-200 dark:bg-white/20"></div>
                                            <div class="mt-2 h-8 w-24 rounded-lg bg-accent"></div>
                                        </div>
                                        <div class="ml-auto h-24 w-32 rounded-xl bg-slate-200 dark:bg-white/10"></div>
                                    </div>
                                    <div class="grid grid-cols-3 gap-3.5">
                                        <div class="h-16 rounded-lg bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10"></div>
                                        <div class="h-16 rounded-lg bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10"></div>
                                        <div class="h-16 rounded-lg bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- ── AUTOMATION CARD ── pipeline diagram -->
                <div class="relative flex flex-col justify-center gap-5 sm:gap-7 px-4 sm:px-6 py-5 sm:py-7
                            bg-slate-50 dark:bg-slate-900/80 h-[300px] sm:h-[380px]">
                    <!-- Live indicator -->
                    <div class="absolute top-4 right-4 sm:top-5 sm:right-5 flex items-center gap-1.5">
                        <span class="size-2 rounded-full bg-green-500 dark:bg-green-400 shadow-[0_0_6px_rgba(74,222,128,0.6)]"></span>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-green-600 dark:text-green-400">Running</span>
                    </div>

                    <!-- Pipeline steps (scrolls horizontally on small screens if there are many) -->
                    <div class="overflow-x-auto" style="min-height:120px;">
                    <div class="flex h-full items-center justify-center gap-0 min-w-min">
                        @{
                            var steps = Current.PipelineSteps.OrderBy(s => s.DisplayOrder).ToList();
                        }
                        @if (steps.Count == 0)
                        {
                            <p class="text-sm text-slate-400 dark:text-slate-600">No pipeline steps configured.</p>
                        }
                        else
                        {
                            @for (int si = 0; si < steps.Count; si++)
                            {
                                var step = steps[si];
                                var isLast = si == steps.Count - 1;
                                <div class="flex items-center gap-0 shrink-0">
                                    <div class="flex flex-col items-center gap-2 sm:gap-2.5">
                                        <div class="flex size-12 sm:size-16 items-center justify-center rounded-xl sm:rounded-2xl border @PipeStepClasses(step.StepType)">
                                            @PipeStepIcon(step.StepType)
                                        </div>
                                        <span class="text-[10px] sm:text-[11px] text-slate-500 dark:text-slate-400 text-center leading-tight font-medium break-words max-w-[56px] sm:max-w-[72px]">@step.Label</span>
                                    </div>
                                    @if (!isLast)
                                    {
                                        <div class="relative mx-1.5 sm:mx-2.5 mb-6 sm:mb-7 w-7 sm:w-11">
                                            <div class="h-0.5 w-full bg-slate-300 dark:bg-slate-700"></div>
                                            <div class="absolute right-0 top-1/2 -translate-y-1/2
                                                        border-t-[6px] border-b-[6px] border-l-[7px]
                                                        border-t-transparent border-b-transparent
                                                        border-l-slate-300 dark:border-l-slate-700"
                                                 style="width:0;height:0;"></div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                    </div>

                    <!-- Integrations row -->
                    @{
                        var integrations = Current.Integrations.OrderBy(i => i.DisplayOrder).ToList();
                    }
                    @if (integrations.Count > 0)
                    {
                        <div class="flex items-center gap-2 flex-wrap justify-center">
                            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 dark:text-slate-600 mr-0.5">Connects:</span>
                            @foreach (var intg in integrations)
                            {
                                <span class="text-xs font-semibold
                                             text-slate-600 dark:text-slate-300
                                             bg-white dark:bg-white/5
                                             border border-slate-200 dark:border-slate-700
                                             px-3 py-1.5 rounded-lg shadow-sm">@intg.Name</span>
                            }
                        </div>
                    }
                </div>
            }

            <!-- ── Shared card body ── -->
            <div class="px-5 py-4 flex flex-col gap-3.5 flex-1
                        border-t border-slate-100 dark:border-slate-700/40">
                <!-- Name + type badge -->
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-base font-semibold text-slate-900 dark:text-white leading-snug truncate">@Current.Name</p>
                        @if (!string.IsNullOrWhiteSpace(Current.HeroTagline))
                        {
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 leading-snug">@Current.HeroTagline</p>
                        }
                    </div>
                    <span class="flex-shrink-0 flex items-center gap-1.5 text-[11px] font-bold px-2.5 py-1 rounded-full @TypeBadgeClasses(Current.Type)">
                        @if (Current.Type == ProjectType.Website)
                        {
                            <Icon Name="IconName.GlobeAlt" Size="IconSize.Small" />
                            <span>Website</span>
                        }
                        else
                        {
                            <Icon Name="IconName.Bolt" Size="IconSize.Small" />
                            <span>Automation</span>
                        }
                    </span>
                </div>

                <!-- Metrics -->
                @{
                    var metrics = Current.Metrics.OrderBy(m => m.DisplayOrder).Take(3).ToList();
                }
                @if (metrics.Count > 0)
                {
                    <div class="grid gap-2.5" style="grid-template-columns: repeat(@metrics.Count, 1fr)">
                        @foreach (var metric in metrics)
                        {
                            <div class="flex flex-col gap-1 sm:gap-1.5 rounded-xl px-2.5 py-2.5 sm:px-3.5 sm:py-3
                                        bg-slate-50 dark:bg-white/5
                                        border border-slate-200 dark:border-slate-700/60">
                                <Icon Name="@MetricIcon(metric.Style)" Size="IconSize.Medium"
                                      Class="@MetricIconClass(metric.Style)" />
                                <span class="text-base sm:text-xl font-bold leading-none @MetricValueClass(metric.Style)">@metric.Value</span>
                                <span class="text-[10px] sm:text-[11px] text-slate-500 dark:text-slate-400 leading-tight">@metric.Label</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Carousel dots + counter -->
        @if (Projects.Count > 1)
        {
            <div class="flex items-center justify-between">
                <div class="flex gap-2 items-center">
                    @for (int di = 0; di < Projects.Count; di++)
                    {
                        var dot_i = di;
                        <button @onclick="() => GoTo(dot_i)" aria-label="Go to project @(di + 1)"
                                class="@(di == _index
                                    ? "w-5 h-2 rounded-full bg-accent"
                                    : "size-2 rounded-full bg-slate-300 dark:bg-slate-700 hover:bg-slate-400 dark:hover:bg-slate-500")
                                    transition-all duration-200">
                        </button>
                    }
                </div>
                <span class="text-[11px] font-semibold text-slate-400 dark:text-slate-600">@(_index + 1) of @Projects.Count</span>
            </div>
        }

    </div>
}

@code {
    [Parameter, EditorRequired]
    public List<ClientProject> Projects { get; set; } = [];

    private int _index = 0;
    private ClientProject Current => Projects[_index];

    private string IframeId => $"hero-iframe-{_index}";
    private string FallbackId => $"hero-fallback-{_index}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Projects.Count == 0) return;
        if (Current.Type == ProjectType.Website && !string.IsNullOrWhiteSpace(Current.PreviewUrl))
        {
            await JS.InvokeVoidAsync("heroCarousel.tryLoadIframe", IframeId, FallbackId);
        }
    }

    private void Next()
    {
        _index = (_index + 1) % Projects.Count;
    }

    private void Prev()
    {
        _index = (_index - 1 + Projects.Count) % Projects.Count;
    }

    private void GoTo(int i)
    {
        if (i >= 0 && i < Projects.Count) _index = i;
    }

    private static string TypeBadgeClasses(ProjectType type) => type switch
    {
        ProjectType.Website    => "bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-500/20",
        ProjectType.Automation => "bg-orange-500/10 text-orange-600 dark:text-orange-400 border border-orange-500/20",
        _ => ""
    };

    private static string PipeStepClasses(PipelineStepType type) => type switch
    {
        PipelineStepType.Trigger => "bg-orange-500/10 border-orange-500/30 text-orange-600 dark:text-orange-400",
        PipelineStepType.Process => "bg-blue-500/10 border-blue-500/25 text-blue-600 dark:text-blue-400",
        PipelineStepType.Output  => "bg-green-500/10 border-green-500/25 text-green-600 dark:text-green-400",
        _ => ""
    };

    private RenderFragment PipeStepIcon(PipelineStepType type) => type switch
    {
        PipelineStepType.Trigger => @<Icon Name="IconName.DocumentText" Size="IconSize.Large" />,
        PipelineStepType.Process => @<Icon Name="IconName.Settings" Size="IconSize.Large" />,
        PipelineStepType.Output  => @<Icon Name="IconName.Message" Size="IconSize.Large" />,
        _ => @<Icon Name="IconName.Settings" Size="IconSize.Large" />
    };

    private static IconName MetricIcon(MetricStyle style) => style switch
    {
        MetricStyle.Up    => IconName.ArrowTrendingUp,
        MetricStyle.Speed => IconName.Bolt,
        MetricStyle.Warm  => IconName.Clock,
        _                 => IconName.CheckCircle
    };

    private static string MetricIconClass(MetricStyle style) => style switch
    {
        MetricStyle.Up    => "text-green-500 dark:text-green-400",
        MetricStyle.Speed => "text-blue-500 dark:text-blue-400",
        MetricStyle.Warm  => "text-orange-500 dark:text-orange-400",
        _                 => "text-slate-400 dark:text-slate-500"
    };

    private static string MetricValueClass(MetricStyle style) => style switch
    {
        MetricStyle.Up    => "text-green-600 dark:text-green-400",
        MetricStyle.Speed => "text-blue-600 dark:text-blue-400",
        MetricStyle.Warm  => "text-orange-600 dark:text-orange-400",
        _                 => "text-slate-900 dark:text-white"
    };
}
