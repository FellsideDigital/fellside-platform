@using FellsideDigital.UI.Components.Buttons
@using FellsideDigital.UI.Layout
@using FellsideDigital.Web.Components.Account.Pages.Manage
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing

<nav id="site-nav"
     class="fixed inset-x-0 top-0 z-50
    border-b border-gray-200 dark:border-white/10
    bg-white/80 dark:bg-gray-900/80
    backdrop-blur-2xl backdrop-saturate-200
    supports-[backdrop-filter]:bg-white/70
    dark:supports-[backdrop-filter]:bg-gray-900/70">

    <div class="@ContainerClass">
        <div class="relative flex h-16 justify-between">

            <div class="absolute inset-y-0 left-0 flex items-center sm:hidden">
                <MobileToggle IsOpen="_mobileMenuOpen" Toggle="ToggleMobileMenu"/>
            </div>

            <div class="flex flex-1 items-center justify-center sm:items-stretch sm:justify-start">
                
                <NavLink href="/" class="flex items-center gap-2.5">
                    <img src="/imgs/svgs/fellside-tarn-indigo.svg"
                         class="h-8 w-auto dark:hidden" alt="Fellside Digital" />
                    <img src="/imgs/svgs/fellside-tarn-orange.svg"
                         class="h-8 w-auto hidden dark:block" alt="Fellside Digital" />
                    <span class="text-[15px] font-semibold text-slate-900 dark:text-white select-none hidden sm:inline">
                        Fellside Digital
                    </span>
                </NavLink>

                <div class="hidden sm:ml-6 sm:flex sm:items-stretch sm:space-x-8">
                    <NavLinks Links="_navLinks"
                              BaseClass="flex space-x-8"
                              LinkClass="inline-flex items-center px-1 pt-1 border-b-2 border-transparent text-sm font-medium text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-white/20 hover:text-gray-700 dark:hover:text-gray-200 transition-all duration-150"
                              ActiveClass="inline-flex items-center px-1 pt-1 border-b-2 border-accent text-sm font-medium text-gray-900 dark:text-white transition-all duration-150"
                              Match="NavLinkMatch.All" />

                    <NavDropdown Label="Services"
                                 Items="_servicesLinks"
                                 TriggerClass="px-1 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors duration-150"
                                 ActiveTriggerClass="px-1 text-sm font-medium text-gray-900 dark:text-white transition-colors duration-150"
                                 ItemClass="font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-white/5 hover:text-gray-900 dark:hover:text-white transition-colors duration-100"
                                 ActiveItemClass="font-semibold text-accent bg-accent-hover" />
                </div>
            </div>

            <div class="absolute inset-y-0 right-0 flex items-center pr-2 sm:static sm:inset-auto sm:ml-6 sm:pr-0">
                <AuthorizeView>
                    <Authorized>
                        <AuthorizeView Roles="SiteAdmin">
                            <Authorized Context="adminCtx">
                                <NavLink href="/Admin/Invitations"
                                         class="mr-2 inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-xs font-semibold text-accent ring-1 ring-accent-hover hover:bg-accent-hover transition-colors">
                                    Admin
                                </NavLink>
                            </Authorized>
                            <NotAuthorized Context="nonAdminCtx">
                                <NavLink href="/Portal"
                                         class="mr-2 inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-xs font-semibold text-accent ring-1 ring-accent-hover hover:bg-accent-hover transition-colors">
                                    My Portal
                                </NavLink>
                            </NotAuthorized>
                        </AuthorizeView>
                        <NotificationBell HasNotifications="_hasNotifications" />
                        <UserMenu CurrentUrl="@currentUrl" />
                    </Authorized>

                    <NotAuthorized>
                        <NavLink href="/Account/Login"
                                 class="ml-3 inline-flex items-center gap-2 text-sm font-semibold text-slate-700 dark:text-neutral-200 hover:text-accent">
                            Login →
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>

    <MobileMenu Links="_mobileNavLinks"
                IsOpen="_mobileMenuOpen"
                Close="CloseMobileMenu"
                CurrentUrl="currentUrl" />
</nav>