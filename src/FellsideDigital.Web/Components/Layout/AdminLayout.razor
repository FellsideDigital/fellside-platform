@using FellsideDigital.UI.Components.Icons
@using FellsideDigital.Web.Components.Account.Pages.Manage
@inherits LayoutComponentBase

<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

<!-- Mobile sidebar drawer -->
@if (_sidebarOpen)
{
    <div class="relative z-50 lg:hidden" role="dialog" aria-modal="true">
        <div class="fixed inset-0 bg-neutral-950/60 backdrop-blur-sm transition-opacity"
             @onclick="CloseSidebar"></div>
        <div class="fixed inset-y-0 left-0 flex w-64 flex-col
                    bg-white dark:bg-neutral-900
                    border-r border-slate-200 dark:border-white/10
                    shadow-xl overflow-hidden">
            <!-- Drawer header -->
            <div class="flex items-center justify-between h-14 px-4 border-b border-slate-200 dark:border-white/10 shrink-0">
                <NavLink href="/" class="flex items-center gap-2.5">
                    <FellsideLogo />
                </NavLink>
                <button type="button"
                        class="p-1.5 rounded-lg text-slate-400 hover:text-slate-600
                               dark:text-neutral-500 dark:hover:text-neutral-300
                               hover:bg-slate-100 dark:hover:bg-white/5 transition-colors"
                        @onclick="CloseSidebar">
                    <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <AdminSidebarContent UserName="@_displayName" UserInitials="@_initials" />
        </div>
    </div>
}

<header class="sticky top-0 z-30 h-14 flex items-center justify-between gap-4 px-4 sm:px-6
               bg-white/80 dark:bg-neutral-900/80 backdrop-blur-xl
               border-b border-slate-200 dark:border-white/10">

    <!-- Left: burger (mobile) + logo + search -->
    <div class="flex items-center gap-3 min-w-0">

        <!-- Mobile burger -->
        <button type="button"
                class="lg:hidden p-1.5 -ml-1 rounded-lg
                       text-slate-500 dark:text-neutral-400
                       hover:bg-slate-100 dark:hover:bg-white/5 transition-colors"
                @onclick="OpenSidebar">
            <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
        </button>

        <!-- Logo -->
        <NavLink href="/" class="flex items-center gap-2 shrink-0">
            <FellsideLogo IncludeText="true" />
        </NavLink>

        <!-- Search pill -->
@*         <div class="hidden sm:flex items-center gap-2 px-3.5 py-2 rounded-full text-sm
                    text-slate-400 dark:text-neutral-500
                    bg-slate-100 dark:bg-neutral-800
                    min-w-[200px] lg:min-w-[280px] cursor-text select-none">
            <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
            <span>Search projects, invoices…</span>
        </div> *@
    </div>

    <!-- Right: theme toggle + user chip -->
    <div class="flex items-center gap-2 shrink-0">
        <DarkModeToggle Size="26" />
        <UserMenu />
@*         <NavigationButton Href="/Portal/Settings">
            <div class="flex size-7 shrink-0 items-center justify-center rounded-full
                        bg-accent text-[11px] font-bold text-white">
                @(_initials.Length > 0 ? _initials : "?")
            </div>
            <span class="hidden sm:block text-sm font-medium text-slate-900 dark:text-white max-w-[120px] truncate">
                @_displayName
            </span>
        </NavigationButton> *@
    </div>
</header>

<!-- Body: sidebar + main -->
<div class="flex">
    <!-- Desktop sidebar: sticky below topbar -->
    <aside class="hidden lg:flex lg:flex-col lg:w-[260px] lg:shrink-0
                  lg:sticky lg:top-14 lg:h-[calc(100vh-3.5rem)] lg:overflow-y-auto
                  bg-white dark:bg-neutral-900
                  border-r border-slate-200 dark:border-white/10">
            <AdminSidebarContent UserName="@_displayName" UserInitials="@_initials" />
    </aside>

    <!-- Main content -->
    <main class=" bg-white dark:bg-neutral-900 flex-1 min-w-0 min-h-[calc(100vh-3.5rem)]">
        <div class="px-4 pt-5 pb-12 sm:px-6 lg:px-8 lg:pt-6">
            @Body
        </div>
    </main>

</div>
