@using System.Security.Claims
@using FellsideDigital.UI.Components.Icons
@using FellsideDigital.UI.Enums
@using FellsideDigital.Web.Components.Account.Pages.Manage
@using Microsoft.AspNetCore.Identity
@using FellsideDigital.Web.Data
@inherits LayoutComponentBase

<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

@if (_sidebarOpen)
{
    <div class="relative z-50 lg:hidden" role="dialog" aria-modal="true">
        <div class="fixed inset-0 bg-gray-900/80 transition-opacity duration-300 ease-linear" @onclick="CloseSidebar"></div>

        <div tabindex="0" class="fixed inset-0 flex focus:outline-none">
            <div class="relative mr-16 flex w-full max-w-xs flex-1 transform transition duration-300 ease-in-out">
                <div class="absolute top-0 left-full flex w-16 justify-center pt-5 duration-300 ease-in-out">
                    <button type="button" class="-m-2.5 p-2.5" @onclick="CloseSidebar">
                        <span class="sr-only">Close sidebar</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6 text-white">
                            <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                </div>

                <div class="relative flex grow flex-col gap-y-5 overflow-y-auto bg-white px-6 pb-2 dark:bg-gray-900 dark:before:pointer-events-none dark:before:absolute dark:before:inset-0 dark:before:border-r dark:before:border-white/10 dark:before:bg-black/10">
                    <AdminSidebarContent UserName="@_displayName" UserInitials="@_initials" />
                </div>
            </div>
        </div>
    </div>
}

<header class="sticky top-0 z-30 h-14 flex items-center justify-between gap-4 px-4 sm:px-6
               bg-white/80 dark:bg-neutral-900/80 backdrop-blur-xl
               border-b border-slate-200 dark:border-white/10">

    <!-- Left: burger (mobile) + logo + search -->
    <div class="flex items-center gap-3 min-w-0">

        <!-- Mobile burger -->
        <button type="button"
                class="lg:hidden p-1.5 -ml-1 rounded-lg
                       text-slate-500 dark:text-neutral-400
                       hover:bg-slate-100 dark:hover:bg-white/5 transition-colors"
                @onclick="OpenSidebar">
            <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
        </button>

        <!-- Logo -->
        <NavLink href="/" class="flex items-center gap-2 shrink-0">
            <FellsideLogo />
        </NavLink>

        <!-- Search pill -->
@*         <div class="hidden sm:flex items-center gap-2 px-3.5 py-2 rounded-full text-sm
                    text-slate-400 dark:text-neutral-500
                    bg-slate-100 dark:bg-neutral-800
                    min-w-[200px] lg:min-w-[280px] cursor-text select-none">
            <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
            <span>Search projects, invoices…</span>
        </div> *@
    </div>

    <!-- Right: theme toggle + user chip -->
    <div class="flex items-center gap-2 shrink-0">
        <DarkModeToggle Size="26" />
        <UserMenu />
@*         <NavigationButton Href="/Portal/Settings">
            <div class="flex size-7 shrink-0 items-center justify-center rounded-full
                        bg-accent text-[11px] font-bold text-white">
                @(_initials.Length > 0 ? _initials : "?")
            </div>
            <span class="hidden sm:block text-sm font-medium text-slate-900 dark:text-white max-w-[120px] truncate">
                @_displayName
            </span>
        </NavigationButton> *@
    </div>
</header>

<!-- Body: sidebar + main -->
<div class="flex">
    <!-- Desktop sidebar: sticky below topbar -->
    <aside class="hidden lg:flex lg:flex-col lg:w-[260px] lg:shrink-0
                  lg:sticky lg:top-14 lg:h-[calc(100vh-3.5rem)] lg:overflow-y-auto
                  bg-white dark:bg-neutral-900
                  border-r border-slate-200 dark:border-white/10">
            <AdminSidebarContent UserName="@_displayName" UserInitials="@_initials" />
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-w-0 min-h-[calc(100vh-3.5rem)] bg-white dark:bg-neutral-950">
        <div class="px-4 pt-5 pb-12 sm:px-6 lg:px-8 lg:pt-6">
            @Body
        </div>
    </main>

</div>
