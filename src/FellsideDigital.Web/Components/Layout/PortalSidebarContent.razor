@using FellsideDigital.UI.Components.Icons
@using FellsideDigital.UI.Components.Navigation
@using Microsoft.AspNetCore.Components.Routing

<nav class="flex flex-col flex-1 py-5 px-3 gap-0.5 overflow-y-auto">

    <!-- Workspace section -->
    <p class="px-2.5 mb-1.5 text-[11px] font-semibold uppercase tracking-[0.15em]
              text-slate-400 dark:text-neutral-500">
        Workspace
    </p>

    <NavigationButton Href="/Portal" Match="NavLinkMatch.All" Icon="IconName.Home">
        Overview
    </NavigationButton>

    <NavigationButton Href="/Portal/Projects" Disabled="true" Icon="IconName.Projects">
        Projects
    </NavigationButton>

    <NavigationButton Href="/Portal/Invoices" Icon="IconName.Invoice">
        Invoices
    </NavigationButton>

    <NavigationButton Href="/Portal/Files" Disabled="true" Icon="IconName.Files">
        Files
    </NavigationButton>

    <NavigationButton Href="/Portal/Messages" Disabled="true" Icon="IconName.Message">
        Messages
    </NavigationButton>

    <NavigationButton Href="/Portal/Settings" Icon="IconName.Settings">
        Settings
    </NavigationButton>

    <!-- Projects -->
    <p class="px-2.5 mt-4 mb-1.5 text-[11px] font-semibold uppercase tracking-[0.15em]
              text-slate-400 dark:text-neutral-500">
        Your Projects
    </p>

    <!-- User chip -->
    <div class="mt-auto pt-4 border-t border-slate-200/80 dark:border-white/5">
        <NavLink href="/Portal/Settings"
                 class="flex items-center gap-2.5 px-2.5 py-2 rounded-[10px]
                        hover:bg-slate-100 dark:hover:bg-white/5 transition-colors group">
            <div class="flex size-8 shrink-0 items-center justify-center rounded-full
                        bg-accent text-xs font-bold text-white">
                @(UserInitials.Length > 0 ? UserInitials : "?")
            </div>
            <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-slate-900 dark:text-white truncate">@UserName</p>
                @if (!string.IsNullOrEmpty(CompanyName))
                {
                    <p class="text-xs text-slate-400 dark:text-neutral-500 truncate">@CompanyName</p>
                }
            </div>
            <svg class="size-4 text-slate-300 dark:text-neutral-600 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity"
                 fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
        </NavLink>
    </div>

</nav>

@code {
    [Parameter] public string UserName { get; set; } = "";
    [Parameter] public string UserInitials { get; set; } = "";
    [Parameter] public string CompanyName { get; set; } = "";
}
