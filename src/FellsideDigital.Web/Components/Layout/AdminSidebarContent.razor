@using FellsideDigital.UI.Components.Icons
@using FellsideDigital.UI.Components.Navigation
@using Microsoft.AspNetCore.Components.Routing

<nav class="flex flex-col flex-1 py-5 px-3 gap-0.5 overflow-y-auto">

    <!-- Clients section -->
    <p class="px-2.5 mb-1.5 text-[11px] font-semibold uppercase tracking-[0.15em]
              text-slate-400 dark:text-neutral-500">
        Clients
    </p>

    <NavigationButton Href="/Admin/Projects" Match="NavLinkMatch.All" Icon="IconName.Projects">
        Projects
    </NavigationButton>

    <NavigationButton Href="/Admin/Invitations" Match="NavLinkMatch.All" Icon="IconName.UserCircle">
        Invitations
    </NavigationButton>

    <NavigationButton Href="/Admin/Enquiries" Match="NavLinkMatch.All" Icon="IconName.Message">
        Enquiries
    </NavigationButton>

    <NavigationButton Href="/Admin/QrCampaign" Match="NavLinkMatch.All" Icon="IconName.ArrowTrendingUp">
        QR Campaign
    </NavigationButton>

    <!-- Portal section -->
    <p class="px-2.5 mt-4 mb-1.5 text-[11px] font-semibold uppercase tracking-[0.15em]
              text-slate-400 dark:text-neutral-500">
        Portal
    </p>

    <NavigationButton Href="/Portal" Match="NavLinkMatch.All" Icon="IconName.GlobeAlt">
        View as Client
    </NavigationButton>

    <!-- User chip -->
    <div class="mt-auto pt-4 border-t border-slate-200/80 dark:border-white/5">
        <div class="flex items-center gap-2.5 px-2.5 py-2 rounded-[10px]">
            <div class="flex size-8 shrink-0 items-center justify-center rounded-full
                        bg-accent text-xs font-bold text-white">
                @(UserInitials.Length > 0 ? UserInitials : "A")
            </div>
            <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-slate-900 dark:text-white truncate">@UserName</p>
                <p class="text-xs text-slate-400 dark:text-neutral-500 truncate">Site Admin</p>
            </div>
        </div>
    </div>

</nav>

@code {
    [Parameter] public string UserName { get; set; } = "";
    [Parameter] public string UserInitials { get; set; } = "";
}
